  events      MatchEvent[]
  playerStats PlayerGameStat[]
  teamStats   TeamGameStat[]

  @@unique([matchId, attemptNumber])
  @@index([matchId, status])
  @@index([inputFingerprint])
}

/// Ordered event feed for a match result (F14).
model MatchEvent {
  id               String   @id @default(cuid())
