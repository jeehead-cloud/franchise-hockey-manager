generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// F1 bootstrap metadata + F3 world initialization state.
model AppMeta {
  id                 String    @id @default("default")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  /// True after a successful one-time world initialization.
  worldInitialized   Boolean   @default(false)
  worldDatasetId     String?
  worldInitializedAt DateTime?
  worldSchemaVersion Int?
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum WorldSeasonStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum WorldSeasonPhase {
  SEASON_PREPARATION
  AGGREGATED_LEAGUES
  NHL_REGULAR_SEASON
  NHL_PLAYOFFS
  WORLD_JUNIOR_CHAMPIONSHIP
  INTERNATIONAL_CHAMPIONSHIP
  SEASON_REVIEW
  ANNUAL_DEVELOPMENT
  OFFSEASON
  NHL_DRAFT
  ROSTER_PREPARATION
  COMPLETE
}

enum LeagueSimulationLevel {
  DETAILED
  AGGREGATED
}

enum CompetitionSimulationLevel {
  DETAILED
  AGGREGATED
}

enum TeamType {
  CLUB
  NATIONAL
}

enum PlayerPosition {
  LW
  RW
  C
  LD
  RD
  G
}

enum PlayerSource {
  REAL_INITIAL_DATA
  GENERATED_YOUTH
  MANUAL
  IMPORTED
}

enum RosterStatus {
  ACTIVE
  RESERVE
  PROSPECT
  UNAVAILABLE
  RETIRED
}

enum CoachingStyle {
  AUTHORITARIAN
  AUTHORITATIVE
  DEMOCRATIC
  DEVELOPMENTAL
  HANDS_OFF
}

enum TacticalStyle {
  COMBINATIONAL
  PHYSICAL
  SPEED
  SYSTEM
  FORECHECKING
}

enum CompetitionType {
  LEAGUE
  PLAYOFF
  INTERNATIONAL_TOURNAMENT
  OTHER
}

enum CompetitionStatus {
  PLANNED
  PREPARING
  READY
  ACTIVE
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum CompetitionStageType {
  REGULAR_SEASON
  ROUND_ROBIN
  GROUP_STAGE
  KNOCKOUT
  BEST_OF_SERIES
  FINAL_RANKING
}

enum CompetitionStageStatus {
  PLANNED
  READY
  /// F18: schedule persisted; matches not yet simulated.
  SCHEDULED
  /// F18: at least one scheduled match simulation has started.
  IN_PROGRESS
  /// Legacy F17 alias retained for existing rows; treat as IN_PROGRESS in F18 logic.
  ACTIVE
  COMPLETED
  CANCELLED
}

/// F18 regular-season schedule generation state (orthogonal to stage status).
enum CompetitionScheduleStatus {
  NONE
  GENERATED
  LOCKED
}

enum StageParticipantSource {
  EDITION_PARTICIPANTS
  PREVIOUS_STAGE_QUALIFIERS
  MANUAL
  FIXED_CONFIG
}

enum CompetitionParticipantStatus {
  INVITED
  CONFIRMED
  WITHDRAWN
  ELIMINATED
  CHAMPION
}

enum CompetitionParticipantSource {
  MANUAL
  LEAGUE_MEMBERSHIP
  QUALIFICATION
  HOST
  DEFENDING_CHAMPION
  IMPORTED
}

enum Personality {
  LEADER
  COMPETITOR
  PROFESSIONAL
  CREATIVE
  GLUE
}

enum PublicPotentialEstimate {
  LOW
  STANDARD
  HIGH
  ELITE
  UNKNOWN
}

enum MatchStatus {
  PREPARED
  SIMULATING
  COMPLETED
  FAILED
  SUPERSEDED
}

enum MatchResultStatus {
  COMPLETED
  SUPERSEDED
  FAILED
}

enum MatchDecisionType {
  REGULATION
  OVERTIME
  SHOOTOUT
  TIE
}

enum MatchSource {
