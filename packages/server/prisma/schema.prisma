generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Bootstrap-only model so Prisma + SQLite wiring exists in F1.
/// Gameplay entities (League, Team, Player, Coach, …) arrive in later milestones.
model AppMeta {
  id        String   @id @default("default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
