model CompetitionArchive {
  id                           String                   @id @default(cuid())
  competitionId                String
  competitionEditionId         String
  worldSeasonId                String
  archiveSchemaVersion         Int
  archiveVersion               Int
  status                       CompetitionArchiveStatus @default(CURRENT)
  competitionNameSnapshot      String
  competitionShortNameSnapshot String?
  editionNameSnapshot          String
  worldSeasonNameSnapshot      String
  competitionTypeSnapshot      String
  simulationLevelSnapshot      String?
  rulesSnapshotText            String
  rulesHash                    String
  engineVersionsText           String
  balanceVersionsText          String
  participantCount             Int
  stageCount                   Int
  matchCount                   Int
  championParticipantSourceId  String?
  championTeamSourceId         String?
  championNameSnapshot         String?
  championShortNameSnapshot    String?
  archiveHash                  String
  sourceSnapshotHash           String
  canonicalSnapshotText        String                   @default("{}")
  archivedAt                   DateTime
  archivedBy                   String?
  reason                       String
  supersedesArchiveId          String?
  supersededByArchiveId        String?
  isCurrent                    Boolean                  @default(true)
  createdAt                    DateTime                 @default(now())

  competition        Competition          @relation(fields: [competitionId], references: [id], onDelete: Restrict)
