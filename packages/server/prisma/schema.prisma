generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// F1 bootstrap metadata + F3 world initialization state.
model AppMeta {
  id                 String    @id @default("default")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  /// True after a successful one-time world initialization.
  worldInitialized   Boolean   @default(false)
  worldDatasetId     String?
  worldInitializedAt DateTime?
  worldSchemaVersion Int?
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum WorldSeasonStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum WorldSeasonPhase {
  SEASON_PREPARATION
  AGGREGATED_LEAGUES
  NHL_REGULAR_SEASON
  NHL_PLAYOFFS
  WORLD_JUNIOR_CHAMPIONSHIP
  INTERNATIONAL_CHAMPIONSHIP
  SEASON_REVIEW
  ANNUAL_DEVELOPMENT
  OFFSEASON
  NHL_DRAFT
  ROSTER_PREPARATION
  COMPLETE
}

enum LeagueSimulationLevel {
  DETAILED
  AGGREGATED
}

enum CompetitionSimulationLevel {
  DETAILED
  AGGREGATED
}

enum TeamType {
  CLUB
  NATIONAL
}

enum PlayerPosition {
  LW
  RW
  C
  LD
  RD
  G
}

enum PlayerSource {
  REAL_INITIAL_DATA
  GENERATED_YOUTH
  MANUAL
  IMPORTED
}

enum RosterStatus {
  ACTIVE
  RESERVE
  PROSPECT
  UNAVAILABLE
}

enum CoachingStyle {
  AUTHORITARIAN
  AUTHORITATIVE
  DEMOCRATIC
  DEVELOPMENTAL
  HANDS_OFF
}

enum TacticalStyle {
  COMBINATIONAL
  PHYSICAL
  SPEED
  SYSTEM
  FORECHECKING
}

enum CompetitionType {
  LEAGUE
  PLAYOFF
  INTERNATIONAL_TOURNAMENT
  OTHER
}

enum CompetitionStatus {
  PLANNED
  PREPARING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum Personality {
  LEADER
  COMPETITOR
  PROFESSIONAL
  CREATIVE
  GLUE
}

enum PublicPotentialEstimate {
  LOW
  STANDARD
  HIGH
  ELITE
  UNKNOWN
}

enum MatchStatus {
  PREPARED
  SIMULATING
  COMPLETED
  FAILED
  SUPERSEDED
}

enum MatchResultStatus {
  COMPLETED
  SUPERSEDED
  FAILED
}

enum MatchDecisionType {
  REGULATION
  OVERTIME
  SHOOTOUT
  TIE
}

enum MatchSource {
  MANUAL
  COMPETITION
}

enum CommissionerAuditEntityType {
  PLAYER
  COACH
  TEAM
  TEAM_LINEUP
  BALANCE_PRESET
  BALANCE_PRESET_VERSION
  ACTIVE_BALANCE_CONFIGURATION
  MATCH
  MATCH_RESULT
}

enum CommissionerAuditAction {
  UPDATE
  MODEL_COMPLETED
  POSITION_MODEL_CONVERTED
  TEAM_ASSIGNMENT_CHANGED
  COACH_UPDATED
  COACH_CREATED
  HEAD_COACH_ASSIGNED
  HEAD_COACH_UNASSIGNED
  TEAM_TACTICS_UPDATED
  PLAYER_ROSTER_STATUS_CHANGED
  LINEUP_CREATED
  LINEUP_UPDATED
  LINEUP_AUTO_FILLED
  LINEUP_CLEARED
  PRESET_DUPLICATED
  PRESET_RENAMED
  VERSION_CREATED
  VERSION_ACTIVATED
  PRESET_RESET
  PRESET_IMPORTED
  MATCH_RESIMULATED
  MATCH_RESULT_SUPERSEDED
}

enum LineupSlot {
  F1_LW
  F1_C
  F1_RW
  F2_LW
  F2_C
  F2_RW
  F3_LW
  F3_C
  F3_RW
  F4_LW
  F4_C
  F4_RW
  D1_LD
  D1_RD
  D2_LD
  D2_RD
  D3_LD
  D3_RD
  G_STARTER
  G_BACKUP
}

enum CommissionerAuditSource {
  COMMISSIONER_UI
  COMMISSIONER_API
}

// ---------------------------------------------------------------------------
// Domain entities (F2 + F3 source metadata)
// ---------------------------------------------------------------------------

/// Global season of the single living hockey world.
model WorldSeason {
  id            String            @id @default(cuid())
  label         String            @unique
  startYear     Int
  endYear       Int
  phase         WorldSeasonPhase
  status        WorldSeasonStatus
  sourceDataset String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  competitionEditions CompetitionEdition[]
}

model Country {
  id              String    @id @default(cuid())
  name            String    @unique
  code            String    @unique
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  leagues League[]
  teams   Team[]
  players Player[] @relation("PlayerNationality")
  coaches Coach[]  @relation("CoachNationality")

  @@unique([sourceDataset, externalId])
}

model League {
  id              String                @id @default(cuid())
  name            String
  shortName       String?
  countryId       String?
  simulationLevel LeagueSimulationLevel
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  country Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)
  teams   Team[]

  @@unique([countryId, name])
  @@unique([sourceDataset, externalId])
  @@index([countryId])
}

model Team {
  id              String         @id @default(cuid())
  name            String
  shortName       String?
  city            String?
  teamType        TeamType
  countryId       String
  leagueId        String?
  /// Team-wide tactical configuration (separate from coach.tacticalStyle).
  tacticalStyle   TacticalStyle?
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict)
  league  League? @relation(fields: [leagueId], references: [id], onDelete: Restrict)

  players     Player[]
  /// At most one current head coach (unique on Coach.currentTeamId).
  coach       Coach?
  lineup      TeamLineup?
  homeMatches Match[]     @relation("MatchHomeTeam")
  awayMatches Match[]     @relation("MatchAwayTeam")

  @@unique([leagueId, name])
  @@unique([sourceDataset, externalId])
  @@index([countryId])
  @@index([leagueId])
}

/// Player identity + F5 development profile. Attributes live in 1:1 skater/goalie tables.
/// Age: `dateOfBirth` (DateTime); age is derived later relative to world/competition date.
model Player {
  id                      String                   @id @default(cuid())
  firstName               String
  lastName                String
  dateOfBirth             DateTime
  nationalityCountryId    String
  currentTeamId           String?
  primaryPosition         PlayerPosition
  sourceType              PlayerSource
  rosterStatus            RosterStatus
  externalId              String?
  sourceDataset           String?
  sourceUpdatedAt         DateTime?
  /// F5 development profile (nullable for legacy F4 structural players).
  preferredCoachingStyle  CoachingStyle?
  preferredTactics        TacticalStyle?
  personality             Personality?
  heroRating              Int?
  stability               Int?
  developmentRate         Float?
  /// Hidden — never expose on ordinary public player APIs.
  developmentRisk         Float?
  /// Hidden — never expose on ordinary public player APIs.
  potentialFloor          Int?
  /// Hidden — never expose on ordinary public player APIs.
  potentialCeiling        Int?
  publicPotentialEstimate PublicPotentialEstimate?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  nationality        Country                   @relation("PlayerNationality", fields: [nationalityCountryId], references: [id], onDelete: Restrict)
  currentTeam        Team?                     @relation(fields: [currentTeamId], references: [id], onDelete: SetNull)
  skaterAttributes   SkaterAttributes?
  goalieAttributes   GoalieAttributes?
  secondaryPositions PlayerSecondaryPosition[]
  lineupAssignments  LineupAssignment[]

  @@unique([sourceDataset, externalId])
  @@index([nationalityCountryId])
  @@index([currentTeamId])
  @@index([primaryPosition])
}

/// Skater-only attributes (1–20). Mutual exclusion with GoalieAttributes enforced in services/import.
model SkaterAttributes {
  playerId           String   @id
  stickhandling      Int
  shooting           Int
  passing            Int
  strength           Int
  speed              Int
  balance            Int
  aggression         Int
  offensiveAwareness Int
  defensiveAwareness Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

/// Goalie-only attributes (1–20). Mutual exclusion with SkaterAttributes enforced in services/import.
model GoalieAttributes {
  playerId       String   @id
  reflexes       Int
  positioning    Int
  reboundControl Int
  glove          Int
  blocker        Int
  movement       Int
  puckHandling   Int
  consistency    Int
  stamina        Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

/// Optional secondary skater positions (F8). Goalies must have none; primary excluded.
model PlayerSecondaryPosition {
  id        String         @id @default(cuid())
  playerId  String
  position  PlayerPosition
  createdAt DateTime       @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, position])
  @@index([position])
}

/// One main lineup per team (F8). Partial lineups allowed; validation is derived.
model TeamLineup {
  id        String   @id @default(cuid())
  teamId    String   @unique
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team        Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments LineupAssignment[]
}

model LineupAssignment {
  id        String     @id @default(cuid())
  lineupId  String
  slot      LineupSlot
  playerId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  lineup TeamLineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  player Player     @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([lineupId, slot])
  @@unique([lineupId, playerId])
  @@index([playerId])
}

model Coach {
  id                   String        @id @default(cuid())
  firstName            String
  lastName             String
  nationalityCountryId String?
  /// Unique when set — enforces at most one current head coach per team.
  currentTeamId        String?       @unique
  coachingStyle        CoachingStyle
  tacticalStyle        TacticalStyle
  /// F7 coach ratings (1–20). Nullable for legacy F6 rows until reimport/backfill.
  overallCoaching      Int?
  playerDevelopment    Int?
  offense              Int?
  defense              Int?
  externalId           String?
  sourceDataset        String?
  sourceUpdatedAt      DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  nationality Country? @relation("CoachNationality", fields: [nationalityCountryId], references: [id], onDelete: Restrict)
  currentTeam Team?    @relation(fields: [currentTeamId], references: [id], onDelete: SetNull)

  @@unique([sourceDataset, externalId])
  @@index([nationalityCountryId])
}

model Competition {
  id              String                      @id @default(cuid())
  name            String
  shortName       String?
  type            CompetitionType
  simulationLevel CompetitionSimulationLevel?
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  editions CompetitionEdition[]

  @@unique([name, type])
  @@unique([sourceDataset, externalId])
}

model CompetitionEdition {
  id            String            @id @default(cuid())
  competitionId String
  worldSeasonId String
  displayName   String
  status        CompetitionStatus
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Restrict)
  worldSeason WorldSeason @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  matches     Match[]

  @@unique([competitionId, worldSeasonId])
  @@index([worldSeasonId])
}

/// Append-only Commissioner edit history (F6). Exposed only via Commissioner-gated APIs.
model CommissionerAuditLog {
  id                String                      @id @default(cuid())
  entityType        CommissionerAuditEntityType
  entityId          String
  action            CommissionerAuditAction
  reason            String
  beforeJson        String
  afterJson         String
  changedFieldsJson String
  source            CommissionerAuditSource
  schemaVersion     Int                         @default(1)
  createdAt         DateTime                    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
}

/// Named balance preset (system Standard or user duplicate). F10.
model BalancePreset {
  id          String                 @id @default(cuid())
  name        String                 @unique
  description String?
  isSystem    Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    BalancePresetVersion[]
}

/// Immutable balance configuration snapshot. F10.
model BalancePresetVersion {
  id              String                      @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                    @default(now())
  createdBySource CommissionerAuditSource?
  preset          BalancePreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor       ActiveBalanceConfiguration?

  @@unique([presetId, versionNumber])
  @@index([configHash])
  @@index([presetId, createdAt])
}

/// Prepared or completed playable match (F14).
model Match {
  id                            String      @id @default(cuid())
  homeTeamId                    String
  awayTeamId                    String
  competitionEditionId          String?
  status                        MatchStatus @default(PREPARED)
  scheduledAt                   DateTime?
  /// Application-level pointer to current MatchResult (no FK constraint).
  currentResultId               String?
  latestSimulationAttemptNumber Int         @default(0)
  source                        MatchSource @default(MANUAL)
  createdBySource               String?
  /// Canonical match rules JSON (regulation + completion).
  rulesJson                     String?
  createdAt                     DateTime    @default(now())
  updatedAt                     DateTime    @updatedAt

  homeTeam           Team                @relation("MatchHomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam           Team                @relation("MatchAwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  competitionEdition CompetitionEdition? @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  results            MatchResult[]

  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([competitionEditionId])
  @@index([status])
  @@index([scheduledAt])
}

/// Immutable simulation attempt for a match (F14).
model MatchResult {
  id                     String            @id @default(cuid())
  matchId                String
  attemptNumber          Int
  status                 MatchResultStatus
  decisionType           MatchDecisionType
  homeScore              Int
  awayScore              Int
  homeRegulationScore    Int
  awayRegulationScore    Int
  homeOvertimeScore      Int               @default(0)
  awayOvertimeScore      Int               @default(0)
  homeShootoutScore      Int               @default(0)
  awayShootoutScore      Int               @default(0)
  winnerTeamId           String?
  engineVersion          String
  simulationMode         String
  randomSeed             String
  inputFingerprint       String
  balancePresetId        String
  balancePresetVersionId String
  balanceVersionNumber   Int
  balanceConfigHash      String
  balanceSnapshotText    String
  simulationInputText    String
  diagnosticsText        String?
  traceHash              String
  reconciliationStatus   String
  reconciliationJson     String?
  startedAt              DateTime
  completedAt            DateTime?
  supersededAt           DateTime?
  supersededByResultId   String?
  createdAt              DateTime          @default(now())

  match       Match            @relation(fields: [matchId], references: [id], onDelete: Restrict)
  events      MatchEvent[]
  playerStats PlayerGameStat[]
  teamStats   TeamGameStat[]

  @@unique([matchId, attemptNumber])
  @@index([matchId, status])
  @@index([inputFingerprint])
}

/// Ordered event feed for a match result (F14).
model MatchEvent {
  id               String   @id @default(cuid())
  matchResultId    String
  eventIndex       Int
  eventType        String
  period           Int
  elapsedSeconds   Int
  remainingSeconds Int
  teamId           String?
  primaryPlayerId  String?
  eventJson        String
  visibility       String
  createdAt        DateTime @default(now())

  matchResult MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Restrict)

  @@unique([matchResultId, eventIndex])
  @@index([matchResultId, period])
}

/// Per-player box score for a match result (F14).
model PlayerGameStat {
  id               String   @id @default(cuid())
  matchResultId    String
  playerId         String
  teamId           String
  position         String
  statsJson        String
  goals            Int      @default(0)
  assists          Int      @default(0)
  points           Int      @default(0)
  shotsOnGoal      Int      @default(0)
  penaltyMinutes   Int      @default(0)
  powerPlayGoals   Int      @default(0)
  shortHandedGoals Int      @default(0)
  shootoutAttempts Int      @default(0)
  shootoutGoals    Int      @default(0)
  createdAt        DateTime @default(now())

  matchResult MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Restrict)

  @@unique([matchResultId, playerId])
  @@index([matchResultId, teamId])
  @@index([playerId])
}

/// Per-team box score for a match result (F14).
model TeamGameStat {
  id               String   @id @default(cuid())
  matchResultId    String
  teamId           String
  side             String
  statsJson        String
  goals            Int      @default(0)
  shotsOnGoal      Int      @default(0)
  penalties        Int      @default(0)
  penaltyMinutes   Int      @default(0)
  powerPlayGoals   Int      @default(0)
  shortHandedGoals Int      @default(0)
  shootoutAttempts Int      @default(0)
  shootoutGoals    Int      @default(0)
  createdAt        DateTime @default(now())

  matchResult MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Restrict)

  @@unique([matchResultId, teamId])
  @@index([matchResultId])
}

/// Singleton active balance version for simulation/runtime. F10.
model ActiveBalanceConfiguration {
  id                    String               @id @default("default")
  activePresetVersionId String               @unique
  updatedAt             DateTime             @updatedAt
  activeVersion         BalancePresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}
