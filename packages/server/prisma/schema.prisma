generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// F1 bootstrap metadata + F3 world initialization state.
model AppMeta {
  id                 String    @id @default("default")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  /// True after a successful one-time world initialization.
  worldInitialized   Boolean   @default(false)
  worldDatasetId     String?
  worldInitializedAt DateTime?
  worldSchemaVersion Int?
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum WorldSeasonStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum WorldSeasonPhase {
  SEASON_PREPARATION
  AGGREGATED_LEAGUES
  NHL_REGULAR_SEASON
  NHL_PLAYOFFS
  WORLD_JUNIOR_CHAMPIONSHIP
  INTERNATIONAL_CHAMPIONSHIP
  SEASON_REVIEW
  ANNUAL_DEVELOPMENT
  OFFSEASON
  NHL_DRAFT
  ROSTER_PREPARATION
  COMPLETE
}

enum LeagueSimulationLevel {
  DETAILED
  AGGREGATED
}

enum CompetitionSimulationLevel {
  DETAILED
  AGGREGATED
}

enum TeamType {
  CLUB
  NATIONAL
}

enum PlayerPosition {
  LW
  RW
  C
  LD
  RD
  G
}

enum PlayerSource {
  REAL_INITIAL_DATA
  GENERATED_YOUTH
  MANUAL
  IMPORTED
}

enum RosterStatus {
  ACTIVE
  RESERVE
  PROSPECT
  UNAVAILABLE
}

enum CoachingStyle {
  AUTHORITARIAN
  AUTHORITATIVE
  DEMOCRATIC
  DEVELOPMENTAL
  HANDS_OFF
}

enum TacticalStyle {
  COMBINATIONAL
  PHYSICAL
  SPEED
  SYSTEM
  FORECHECKING
}

enum CompetitionType {
  LEAGUE
  PLAYOFF
  INTERNATIONAL_TOURNAMENT
  OTHER
}

enum CompetitionStatus {
  PLANNED
  PREPARING
  READY
  ACTIVE
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum CompetitionStageType {
  REGULAR_SEASON
  ROUND_ROBIN
  GROUP_STAGE
  KNOCKOUT
  BEST_OF_SERIES
  FINAL_RANKING
}

enum CompetitionStageStatus {
  PLANNED
  READY
  /// F18: schedule persisted; matches not yet simulated.
  SCHEDULED
  /// F18: at least one scheduled match simulation has started.
  IN_PROGRESS
  /// Legacy F17 alias retained for existing rows; treat as IN_PROGRESS in F18 logic.
  ACTIVE
  COMPLETED
  CANCELLED
}

/// F18 regular-season schedule generation state (orthogonal to stage status).
enum CompetitionScheduleStatus {
  NONE
  GENERATED
  LOCKED
}

enum StageParticipantSource {
  EDITION_PARTICIPANTS
  PREVIOUS_STAGE_QUALIFIERS
  MANUAL
  FIXED_CONFIG
}

enum CompetitionParticipantStatus {
  INVITED
  CONFIRMED
  WITHDRAWN
  ELIMINATED
  CHAMPION
}

enum CompetitionParticipantSource {
  MANUAL
  LEAGUE_MEMBERSHIP
  QUALIFICATION
  HOST
  DEFENDING_CHAMPION
  IMPORTED
}

enum Personality {
  LEADER
  COMPETITOR
  PROFESSIONAL
  CREATIVE
  GLUE
}

enum PublicPotentialEstimate {
  LOW
  STANDARD
  HIGH
  ELITE
  UNKNOWN
}

enum MatchStatus {
  PREPARED
  SIMULATING
  COMPLETED
  FAILED
  SUPERSEDED
}

enum MatchResultStatus {
  COMPLETED
  SUPERSEDED
  FAILED
}

enum MatchDecisionType {
  REGULATION
  OVERTIME
  SHOOTOUT
  TIE
}

enum MatchSource {
  MANUAL
  COMPETITION
}

enum CommissionerAuditEntityType {
  PLAYER
  COACH
  TEAM
  TEAM_LINEUP
  BALANCE_PRESET
  BALANCE_PRESET_VERSION
  ACTIVE_BALANCE_CONFIGURATION
  MATCH
  MATCH_RESULT
  COMPETITION
  COMPETITION_EDITION
  COMPETITION_STAGE
  COMPETITION_PARTICIPANT
}

enum CommissionerAuditAction {
  UPDATE
  MODEL_COMPLETED
  POSITION_MODEL_CONVERTED
  TEAM_ASSIGNMENT_CHANGED
  COACH_UPDATED
  COACH_CREATED
  HEAD_COACH_ASSIGNED
  HEAD_COACH_UNASSIGNED
  TEAM_TACTICS_UPDATED
  PLAYER_ROSTER_STATUS_CHANGED
  LINEUP_CREATED
  LINEUP_UPDATED
  LINEUP_AUTO_FILLED
  LINEUP_CLEARED
  PRESET_DUPLICATED
  PRESET_RENAMED
  VERSION_CREATED
  VERSION_ACTIVATED
  PRESET_RESET
  PRESET_IMPORTED
  MATCH_RESIMULATED
  MATCH_RESULT_SUPERSEDED
  COMPETITION_UPDATED
  EDITION_CREATED
  EDITION_UPDATED
  EDITION_STATUS_CHANGED
  EDITION_RULES_UPDATED
  PARTICIPANT_ADDED
  PARTICIPANT_REMOVED
  PARTICIPANT_UPDATED
  LEAGUE_PARTICIPANTS_ADDED
  STAGE_CREATED
  STAGE_UPDATED
  STAGE_REMOVED
  STAGE_REORDERED
  STAGE_PARTICIPANTS_UPDATED
  SCHEDULE_GENERATED
  SCHEDULE_REGENERATED
  REGULAR_SEASON_SIMULATION_STARTED
  REGULAR_SEASON_SIMULATION_COMPLETED
  QUALIFIERS_IMPORTED
  BRACKET_GENERATED
  BRACKET_REGENERATED
  PLAYOFF_SERIES_COMPLETED
  PLAYOFF_STAGE_COMPLETED
  PLAYOFF_SEEDS_UPDATED
  EDITION_ARCHIVED
  ARCHIVE_SUPERSEDED
}

/// F20 competition archive status.
enum CompetitionArchiveStatus {
  CURRENT
  SUPERSEDED
}

enum ArchiveAwardType {
  CHAMPION
  REGULAR_SEASON_CHAMPION
  MOST_POINTS
  MOST_GOALS
  MOST_ASSISTS
  BEST_GOALIE_SAVE_PERCENTAGE
  PLAYOFF_MOST_POINTS
  PLAYOFF_MOST_GOALS
  BEST_REGULAR_SEASON_RECORD
}

enum ArchiveAwardRecipientType {
  TEAM
  PLAYER
}

enum ArchivePlayoffResult {
  CHAMPION
  FINALIST
  SEMIFINALIST
  QUARTERFINALIST
  DID_NOT_QUALIFY
  ELIMINATED
}

enum PlayoffSeriesStatus {
  PENDING
  READY
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LineupSlot {
  F1_LW
  F1_C
  F1_RW
  F2_LW
  F2_C
  F2_RW
  F3_LW
  F3_C
  F3_RW
  F4_LW
  F4_C
  F4_RW
  D1_LD
  D1_RD
  D2_LD
  D2_RD
  D3_LD
  D3_RD
  G_STARTER
  G_BACKUP
}

enum CommissionerAuditSource {
  COMMISSIONER_UI
  COMMISSIONER_API
}

// ---------------------------------------------------------------------------
// Domain entities (F2 + F3 source metadata)
// ---------------------------------------------------------------------------

/// Global season of the single living hockey world.
model WorldSeason {
  id            String            @id @default(cuid())
  label         String            @unique
  startYear     Int
  endYear       Int
  phase         WorldSeasonPhase
  status        WorldSeasonStatus
  sourceDataset String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  competitionEditions CompetitionEdition[]
  archives            CompetitionArchive[]
}

model Country {
  id              String    @id @default(cuid())
  name            String    @unique
  code            String    @unique
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  leagues      League[]
  teams        Team[]
  players      Player[]      @relation("PlayerNationality")
  coaches      Coach[]       @relation("CoachNationality")
  competitions Competition[]

  @@unique([sourceDataset, externalId])
}

model League {
  id              String                @id @default(cuid())
  name            String
  shortName       String?
  countryId       String?
  simulationLevel LeagueSimulationLevel
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  country      Country?      @relation(fields: [countryId], references: [id], onDelete: Restrict)
  teams        Team[]
  competitions Competition[]

  @@unique([countryId, name])
  @@unique([sourceDataset, externalId])
  @@index([countryId])
}

model Team {
  id              String         @id @default(cuid())
  name            String
  shortName       String?
  city            String?
  teamType        TeamType
  countryId       String
  leagueId        String?
  /// Team-wide tactical configuration (separate from coach.tacticalStyle).
  tacticalStyle   TacticalStyle?
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict)
  league  League? @relation(fields: [leagueId], references: [id], onDelete: Restrict)

  players                 Player[]
  /// At most one current head coach (unique on Coach.currentTeamId).
  coach                   Coach?
  lineup                  TeamLineup?
  homeMatches             Match[]                  @relation("MatchHomeTeam")
  awayMatches             Match[]                  @relation("MatchAwayTeam")
  competitionParticipants CompetitionParticipant[]

  @@unique([leagueId, name])
  @@unique([sourceDataset, externalId])
  @@index([countryId])
  @@index([leagueId])
}

/// Player identity + F5 development profile. Attributes live in 1:1 skater/goalie tables.
/// Age: `dateOfBirth` (DateTime); age is derived later relative to world/competition date.
model Player {
  id                      String                   @id @default(cuid())
  firstName               String
  lastName                String
  dateOfBirth             DateTime
  nationalityCountryId    String
  currentTeamId           String?
  primaryPosition         PlayerPosition
  sourceType              PlayerSource
  rosterStatus            RosterStatus
  externalId              String?
  sourceDataset           String?
  sourceUpdatedAt         DateTime?
  /// F5 development profile (nullable for legacy F4 structural players).
  preferredCoachingStyle  CoachingStyle?
  preferredTactics        TacticalStyle?
  personality             Personality?
  heroRating              Int?
  stability               Int?
  developmentRate         Float?
  /// Hidden — never expose on ordinary public player APIs.
  developmentRisk         Float?
  /// Hidden — never expose on ordinary public player APIs.
  potentialFloor          Int?
  /// Hidden — never expose on ordinary public player APIs.
  potentialCeiling        Int?
  publicPotentialEstimate PublicPotentialEstimate?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  nationality        Country                   @relation("PlayerNationality", fields: [nationalityCountryId], references: [id], onDelete: Restrict)
  currentTeam        Team?                     @relation(fields: [currentTeamId], references: [id], onDelete: SetNull)
  skaterAttributes   SkaterAttributes?
  goalieAttributes   GoalieAttributes?
  secondaryPositions PlayerSecondaryPosition[]
  lineupAssignments  LineupAssignment[]

  @@unique([sourceDataset, externalId])
  @@index([nationalityCountryId])
  @@index([currentTeamId])
  @@index([primaryPosition])
}

/// Skater-only attributes (1–20). Mutual exclusion with GoalieAttributes enforced in services/import.
model SkaterAttributes {
  playerId           String   @id
  stickhandling      Int
  shooting           Int
  passing            Int
  strength           Int
  speed              Int
  balance            Int
  aggression         Int
  offensiveAwareness Int
  defensiveAwareness Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

/// Goalie-only attributes (1–20). Mutual exclusion with SkaterAttributes enforced in services/import.
model GoalieAttributes {
  playerId       String   @id
  reflexes       Int
  positioning    Int
  reboundControl Int
  glove          Int
  blocker        Int
  movement       Int
  puckHandling   Int
  consistency    Int
  stamina        Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

/// Optional secondary skater positions (F8). Goalies must have none; primary excluded.
model PlayerSecondaryPosition {
  id        String         @id @default(cuid())
  playerId  String
  position  PlayerPosition
  createdAt DateTime       @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, position])
  @@index([position])
}

/// One main lineup per team (F8). Partial lineups allowed; validation is derived.
model TeamLineup {
  id        String   @id @default(cuid())
  teamId    String   @unique
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team        Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments LineupAssignment[]
}

model LineupAssignment {
  id        String     @id @default(cuid())
  lineupId  String
  slot      LineupSlot
  playerId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  lineup TeamLineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  player Player     @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([lineupId, slot])
  @@unique([lineupId, playerId])
  @@index([playerId])
}

model Coach {
  id                   String        @id @default(cuid())
  firstName            String
  lastName             String
  nationalityCountryId String?
  /// Unique when set — enforces at most one current head coach per team.
  currentTeamId        String?       @unique
  coachingStyle        CoachingStyle
  tacticalStyle        TacticalStyle
  /// F7 coach ratings (1–20). Nullable for legacy F6 rows until reimport/backfill.
  overallCoaching      Int?
  playerDevelopment    Int?
  offense              Int?
  defense              Int?
  externalId           String?
  sourceDataset        String?
  sourceUpdatedAt      DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  nationality Country? @relation("CoachNationality", fields: [nationalityCountryId], references: [id], onDelete: Restrict)
  currentTeam Team?    @relation(fields: [currentTeamId], references: [id], onDelete: SetNull)

  @@unique([sourceDataset, externalId])
  @@index([nationalityCountryId])
}

model Competition {
  id               String                      @id @default(cuid())
  name             String
  shortName        String?
  type             CompetitionType
  simulationLevel  CompetitionSimulationLevel?
  countryId        String?
  leagueId         String?
  /// Default rules template JSON (copied into edition snapshots on create).
  defaultRulesJson String?
  externalId       String?
  sourceDataset    String?
  sourceUpdatedAt  DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  country  Country?             @relation(fields: [countryId], references: [id], onDelete: Restrict)
  league   League?              @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  editions CompetitionEdition[]
  archives CompetitionArchive[]

  @@unique([name, type])
  @@unique([sourceDataset, externalId])
  @@index([countryId])
  @@index([leagueId])
}

model CompetitionEdition {
  id                String            @id @default(cuid())
  competitionId     String
  worldSeasonId     String
  displayName       String
  status            CompetitionStatus
  editionNumber     Int?
  rulesSnapshotText String            @default("{}")
  rulesHash         String            @default("")
  preparedAt        DateTime?
  activatedAt       DateTime?
  completedAt       DateTime?
  archivedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  competition    Competition              @relation(fields: [competitionId], references: [id], onDelete: Restrict)
  worldSeason    WorldSeason              @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  participants   CompetitionParticipant[]
  stages         CompetitionStage[]
  matches        Match[]
  archives       CompetitionArchive[]
  aggregatedRuns AggregatedSeasonRun[]

  @@unique([competitionId, worldSeasonId])
  @@index([worldSeasonId])
  @@index([status])
}

model CompetitionParticipant {
  id                    String                       @id @default(cuid())
  competitionEditionId  String
  teamId                String
  seed                  Int?
  groupKey              String?
  participantOrder      Int
  status                CompetitionParticipantStatus @default(INVITED)
  source                CompetitionParticipantSource @default(MANUAL)
  teamNameSnapshot      String
  teamShortNameSnapshot String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  edition           CompetitionEdition @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  team              Team               @relation(fields: [teamId], references: [id], onDelete: Restrict)
  stageParticipants StageParticipant[]

  @@unique([competitionEditionId, teamId])
  @@unique([competitionEditionId, participantOrder])
  @@index([teamId])
  @@index([status])
}

model CompetitionStage {
  id                       String                    @id @default(cuid())
  competitionEditionId     String
  name                     String
  stageType                CompetitionStageType
  stageOrder               Int
  status                   CompetitionStageStatus    @default(PLANNED)
  configText               String                    @default("{}")
  configHash               String                    @default("")
  participantSource        StageParticipantSource    @default(EDITION_PARTICIPANTS)
  sourceStageId            String?
  expectedQualifierCount   Int?
  /// F18 schedule metadata
  scheduleStatus           CompetitionScheduleStatus @default(NONE)
  scheduleSeed             String?
  scheduleHash             String?
  scheduleVersion          Int                       @default(0)
  scheduleGeneratedAt      DateTime?
  simulationStartedAt      DateTime?
  completedAt              DateTime?
  /// F19 playoff bracket metadata
  bracketSeed              String?
  bracketHash              String?
  bracketVersion           Int                       @default(0)
  bracketGeneratedAt       DateTime?
  championParticipantId    String?
  championTeamNameSnapshot String?
  championSeed             Int?
  championshipSeriesId     String?
  /// F21 aggregated season
  currentAggregatedRunId   String?
  simulationModeSnapshot   String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  edition           CompetitionEdition           @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  sourceStage       CompetitionStage?            @relation("StageDependency", fields: [sourceStageId], references: [id], onDelete: Restrict)
  dependents        CompetitionStage[]           @relation("StageDependency")
  participants      StageParticipant[]
  matches           Match[]
  standings         CompetitionStageStanding[]
  teamStats         CompetitionStageTeamStat[]
  playerStats       CompetitionStagePlayerStat[]
  playoffSeries     PlayoffSeries[]
  aggregatedRuns    AggregatedSeasonRun[]
  aggregatedMatches AggregatedMatchSummary[]

  @@unique([competitionEditionId, stageOrder])
  @@index([competitionEditionId])
  @@index([stageType])
  @@index([sourceStageId])
  @@index([status])
  @@index([championParticipantId])
}

model StageParticipant {
  id                       String                       @id @default(cuid())
  competitionStageId       String
  competitionParticipantId String
  seed                     Int?
  groupKey                 String?
  stageOrder               Int
  status                   CompetitionParticipantStatus @default(CONFIRMED)
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt

  stage       CompetitionStage       @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  participant CompetitionParticipant @relation(fields: [competitionParticipantId], references: [id], onDelete: Restrict)

  @@unique([competitionStageId, competitionParticipantId])
  @@unique([competitionStageId, stageOrder])
  @@index([competitionParticipantId])
}

/// F19 best-of-series playoff matchup.
model PlayoffSeries {
  id                         String              @id @default(cuid())
  competitionStageId         String
  roundNumber                Int
  roundName                  String
  seriesOrder                Int
  bracketSlot                String
  status                     PlayoffSeriesStatus @default(PENDING)
  participant1Id             String
  participant2Id             String
  participant1Seed           Int
  participant2Seed           Int
  participant1NameSnapshot   String
  participant2NameSnapshot   String
  participant1Wins           Int                 @default(0)
  participant2Wins           Int                 @default(0)
  winsRequired               Int
  homeAdvantageParticipantId String
  homePatternText            String
  winnerParticipantId        String?
  nextSeriesId               String?
  createdAt                  DateTime            @default(now())
  startedAt                  DateTime?
  completedAt                DateTime?
  updatedAt                  DateTime            @updatedAt

  stage   CompetitionStage @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  matches Match[]

  @@unique([competitionStageId, bracketSlot])
  @@unique([competitionStageId, roundNumber, seriesOrder])
  @@index([competitionStageId, roundNumber])
  @@index([winnerParticipantId])
  @@index([status])
}

/// Append-only Commissioner edit history (F6). Exposed only via Commissioner-gated APIs.
model CommissionerAuditLog {
  id                String                      @id @default(cuid())
  entityType        CommissionerAuditEntityType
  entityId          String
  action            CommissionerAuditAction
  reason            String
  beforeJson        String
  afterJson         String
  changedFieldsJson String
  source            CommissionerAuditSource
  schemaVersion     Int                         @default(1)
  createdAt         DateTime                    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
}

/// Named balance preset (system Standard or user duplicate). F10.
model BalancePreset {
  id          String                 @id @default(cuid())
  name        String                 @unique
  description String?
  isSystem    Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    BalancePresetVersion[]
}

/// Immutable balance configuration snapshot. F10.
model BalancePresetVersion {
  id              String                      @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                    @default(now())
  createdBySource CommissionerAuditSource?
  preset          BalancePreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor       ActiveBalanceConfiguration?

  @@unique([presetId, versionNumber])
  @@index([configHash])
  @@index([presetId, createdAt])
}

/// Prepared or completed playable match (F14). Competition schedule fields added in F18.
model Match {
  id                            String      @id @default(cuid())
  homeTeamId                    String
  awayTeamId                    String
  competitionEditionId          String?
  competitionStageId            String?
  status                        MatchStatus @default(PREPARED)
  scheduledAt                   DateTime?
  /// Application-level pointer to current MatchResult (no FK constraint).
  currentResultId               String?
  latestSimulationAttemptNumber Int         @default(0)
  source                        MatchSource @default(MANUAL)
  createdBySource               String?
  /// Canonical match rules JSON (regulation + completion).
  rulesJson                     String?
  /// F18 competition schedule placement (nullable for ad hoc matches).
  competitionRoundNumber        Int?
  competitionSlotNumber         Int?
  scheduleKey                   String?
  scheduleOrder                 Int?
  competitionRulesHash          String?
  /// F19 playoff placement
  playoffSeriesId               String?
  playoffGameNumber             Int?
  createdAt                     DateTime    @default(now())
  updatedAt                     DateTime    @updatedAt

  homeTeam           Team                @relation("MatchHomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam           Team                @relation("MatchAwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  competitionEdition CompetitionEdition? @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  competitionStage   CompetitionStage?   @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  playoffSeries      PlayoffSeries?      @relation(fields: [playoffSeriesId], references: [id], onDelete: Restrict)
  results            MatchResult[]

  @@unique([competitionStageId, scheduleKey])
  @@unique([playoffSeriesId, playoffGameNumber])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([competitionEditionId])
  @@index([competitionStageId])
  @@index([competitionStageId, scheduleOrder])
  @@index([competitionStageId, status])
  @@index([playoffSeriesId])
  @@index([status])
  @@index([scheduledAt])
}

/// Immutable final standings row persisted when a regular-season stage completes (F18).
model CompetitionStageStanding {
  id                       String   @id @default(cuid())
  competitionStageId       String
  competitionParticipantId String
  rank                     Int
  teamId                   String
  teamNameSnapshot         String
  gamesPlayed              Int
  regulationWins           Int
  overtimeWins             Int
  shootoutWins             Int
  regulationLosses         Int
  overtimeLosses           Int
  shootoutLosses           Int
  ties                     Int
  wins                     Int
  losses                   Int
  goalsFor                 Int
  goalsAgainst             Int
  goalDifference           Int
  points                   Int
  pointsPercentage         Float
  qualified                Boolean  @default(false)
  tiebreakerSummaryText    String   @default("")
  statisticsJson           String   @default("{}")
  snapshotHash             String
  createdAt                DateTime @default(now())

  stage CompetitionStage @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)

  @@unique([competitionStageId, competitionParticipantId])
  @@unique([competitionStageId, rank])
  @@index([competitionStageId, qualified])
}

/// Immutable team season-stat snapshot at stage completion (F18).
model CompetitionStageTeamStat {
  id                       String   @id @default(cuid())
  competitionStageId       String
  competitionParticipantId String
  teamId                   String
  teamNameSnapshot         String
  gamesPlayed              Int
  goals                    Int
  goalsAgainst             Int
  shotsOnGoal              Int
  shotAttempts             Int      @default(0)
  penalties                Int
  penaltyMinutes           Int
  powerPlayGoals           Int
  powerPlayOpportunities   Int      @default(0)
  shortHandedGoals         Int
  shootoutAttempts         Int      @default(0)
  shootoutGoals            Int      @default(0)
  shootingPercentage       Float?
  powerPlayPercentage      Float?
  penaltyKillPercentage    Float?
  statsJson                String   @default("{}")
  snapshotHash             String
  createdAt                DateTime @default(now())

  stage CompetitionStage @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)

  @@unique([competitionStageId, teamId])
  @@index([competitionStageId])
}

/// Immutable player/goalie season-stat snapshot at stage completion (F18).
model CompetitionStagePlayerStat {
  id                 String   @id @default(cuid())
  competitionStageId String
  playerId           String
  teamId             String
  teamNameSnapshot   String
  firstNameSnapshot  String
  lastNameSnapshot   String
  position           String
  isGoalie           Boolean  @default(false)
  gamesPlayed        Int
  goals              Int
  assists            Int
  points             Int
  shotsOnGoal        Int
  penaltyMinutes     Int
  powerPlayGoals     Int
  shortHandedGoals   Int
  shootoutAttempts   Int      @default(0)
  shootoutGoals      Int      @default(0)
  wins               Int      @default(0)
  losses             Int      @default(0)
  shotsAgainst       Int      @default(0)
  saves              Int      @default(0)
  goalsAgainst       Int      @default(0)
  shutouts           Int      @default(0)
  savePercentage     Float?
  shootingPercentage Float?
  statsJson          String   @default("{}")
  snapshotHash       String
  createdAt          DateTime @default(now())

  stage CompetitionStage @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)

  @@unique([competitionStageId, playerId])
  @@index([competitionStageId, isGoalie])
  @@index([competitionStageId, points])
}

/// Immutable simulation attempt for a match (F14).
model MatchResult {
  id                     String            @id @default(cuid())
  matchId                String
  attemptNumber          Int
  status                 MatchResultStatus
  decisionType           MatchDecisionType
  homeScore              Int
  awayScore              Int
  homeRegulationScore    Int
  awayRegulationScore    Int
  homeOvertimeScore      Int               @default(0)
  awayOvertimeScore      Int               @default(0)
  homeShootoutScore      Int               @default(0)
  awayShootoutScore      Int               @default(0)
  winnerTeamId           String?
  engineVersion          String
  simulationMode         String
  randomSeed             String
  inputFingerprint       String
  balancePresetId        String
  balancePresetVersionId String
  balanceVersionNumber   Int
  balanceConfigHash      String
  balanceSnapshotText    String
  simulationInputText    String
  diagnosticsText        String?
  traceHash              String
  reconciliationStatus   String
  reconciliationJson     String?
  startedAt              DateTime
  completedAt            DateTime?
  supersededAt           DateTime?
  supersededByResultId   String?
  createdAt              DateTime          @default(now())

  match       Match            @relation(fields: [matchId], references: [id], onDelete: Restrict)
  events      MatchEvent[]
  playerStats PlayerGameStat[]
  teamStats   TeamGameStat[]

  @@unique([matchId, attemptNumber])
  @@index([matchId, status])
  @@index([inputFingerprint])
}

/// Ordered event feed for a match result (F14).
model MatchEvent {
  id               String   @id @default(cuid())
  matchResultId    String
  eventIndex       Int
  eventType        String
  period           Int
  elapsedSeconds   Int
  remainingSeconds Int
  teamId           String?
  primaryPlayerId  String?
  eventJson        String
  visibility       String
  createdAt        DateTime @default(now())

  matchResult MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Restrict)

  @@unique([matchResultId, eventIndex])
  @@index([matchResultId, period])
}

/// Per-player box score for a match result (F14).
model PlayerGameStat {
  id               String   @id @default(cuid())
  matchResultId    String
  playerId         String
  teamId           String
  position         String
  statsJson        String
  goals            Int      @default(0)
  assists          Int      @default(0)
  points           Int      @default(0)
  shotsOnGoal      Int      @default(0)
  penaltyMinutes   Int      @default(0)
  powerPlayGoals   Int      @default(0)
  shortHandedGoals Int      @default(0)
  shootoutAttempts Int      @default(0)
  shootoutGoals    Int      @default(0)
  createdAt        DateTime @default(now())

  matchResult MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Restrict)

  @@unique([matchResultId, playerId])
  @@index([matchResultId, teamId])
  @@index([playerId])
}

/// Per-team box score for a match result (F14).
model TeamGameStat {
  id               String   @id @default(cuid())
  matchResultId    String
  teamId           String
  side             String
  statsJson        String
  goals            Int      @default(0)
  shotsOnGoal      Int      @default(0)
  penalties        Int      @default(0)
  penaltyMinutes   Int      @default(0)
  powerPlayGoals   Int      @default(0)
  shortHandedGoals Int      @default(0)
  shootoutAttempts Int      @default(0)
  shootoutGoals    Int      @default(0)
  createdAt        DateTime @default(now())

  matchResult MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Restrict)

  @@unique([matchResultId, teamId])
  @@index([matchResultId])
}

/// Singleton active balance version for simulation/runtime. F10.
model ActiveBalanceConfiguration {
  id                    String               @id @default("default")
  activePresetVersionId String               @unique
  updatedAt             DateTime             @updatedAt
  activeVersion         BalancePresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}

// ---------------------------------------------------------------------------
// F20 — Immutable competition archives
// ---------------------------------------------------------------------------

model CompetitionArchive {
  id                           String                   @id @default(cuid())
  competitionId                String
  competitionEditionId         String
  worldSeasonId                String
  archiveSchemaVersion         Int
  archiveVersion               Int
  status                       CompetitionArchiveStatus @default(CURRENT)
  competitionNameSnapshot      String
  competitionShortNameSnapshot String?
  editionNameSnapshot          String
  worldSeasonNameSnapshot      String
  competitionTypeSnapshot      String
  simulationLevelSnapshot      String?
  rulesSnapshotText            String
  rulesHash                    String
  engineVersionsText           String
  balanceVersionsText          String
  participantCount             Int
  stageCount                   Int
  matchCount                   Int
  championParticipantSourceId  String?
  championTeamSourceId         String?
  championNameSnapshot         String?
  championShortNameSnapshot    String?
  archiveHash                  String
  sourceSnapshotHash           String
  canonicalSnapshotText        String                   @default("{}")
  archivedAt                   DateTime
  archivedBy                   String?
  reason                       String
  supersedesArchiveId          String?
  supersededByArchiveId        String?
  isCurrent                    Boolean                  @default(true)
  createdAt                    DateTime                 @default(now())

  competition        Competition          @relation(fields: [competitionId], references: [id], onDelete: Restrict)
  edition            CompetitionEdition   @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  worldSeason        WorldSeason          @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  supersedes         CompetitionArchive?  @relation("ArchiveSupersession", fields: [supersedesArchiveId], references: [id], onDelete: Restrict)
  supersededVersions CompetitionArchive[] @relation("ArchiveSupersession")

  participants ArchiveParticipant[]
  stages       ArchiveStage[]
  standings    ArchiveStanding[]
  teamStats    ArchiveTeamStat[]
  playerStats  ArchivePlayerStat[]
  matches      ArchiveMatchSummary[]
  series       ArchiveSeries[]
  awards       ArchiveAward[]

  @@unique([competitionEditionId, archiveVersion])
  @@unique([competitionEditionId, archiveHash])
  @@index([competitionId])
  @@index([worldSeasonId])
  @@index([isCurrent])
  @@index([status])
  @@index([archivedAt])
  @@index([championTeamSourceId])
}

model ArchiveParticipant {
  id                             String                @id @default(cuid())
  competitionArchiveId           String
  sourceCompetitionParticipantId String
  sourceTeamId                   String
  participantOrder               Int
  seed                           Int?
  finalStatus                    String
  teamNameSnapshot               String
  teamShortNameSnapshot          String?
  countryNameSnapshot            String?
  leagueNameSnapshot             String?
  groupKey                       String?
  qualifiedForPlayoffs           Boolean               @default(false)
  playoffSeed                    Int?
  finalRegularSeasonRank         Int?
  finalPlayoffResult             ArchivePlayoffResult?
  createdAt                      DateTime              @default(now())

  archive     CompetitionArchive    @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  standings   ArchiveStanding[]
  teamStats   ArchiveTeamStat[]
  playerStats ArchivePlayerStat[]
  homeMatches ArchiveMatchSummary[] @relation("ArchiveMatchHome")
  awayMatches ArchiveMatchSummary[] @relation("ArchiveMatchAway")
  seriesAsP1  ArchiveSeries[]       @relation("ArchiveSeriesP1")
  seriesAsP2  ArchiveSeries[]       @relation("ArchiveSeriesP2")
  seriesWins  ArchiveSeries[]       @relation("ArchiveSeriesWinner")
  awards      ArchiveAward[]

  @@unique([competitionArchiveId, sourceCompetitionParticipantId])
  @@unique([competitionArchiveId, participantOrder])
  @@index([sourceTeamId])
  @@index([competitionArchiveId, qualifiedForPlayoffs])
}

model ArchiveStage {
  id                           String    @id @default(cuid())
  competitionArchiveId         String
  sourceCompetitionStageId     String
  stageOrder                   Int
  stageNameSnapshot            String
  stageType                    String
  finalStatus                  String
  configSnapshotText           String
  configHash                   String
  scheduleHash                 String?
  bracketHash                  String?
  matchCount                   Int
  completedAtSnapshot          DateTime?
  championParticipantArchiveId String?
  sourceStageArchiveId         String?
  snapshotHash                 String
  createdAt                    DateTime  @default(now())

  archive     CompetitionArchive    @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  standings   ArchiveStanding[]
  teamStats   ArchiveTeamStat[]
  playerStats ArchivePlayerStat[]
  matches     ArchiveMatchSummary[]
  series      ArchiveSeries[]
  awards      ArchiveAward[]

  @@unique([competitionArchiveId, sourceCompetitionStageId])
  @@unique([competitionArchiveId, stageOrder])
  @@index([stageType])
}

model ArchiveStanding {
  id                    String   @id @default(cuid())
  competitionArchiveId  String
  archiveStageId        String
  archiveParticipantId  String
  rank                  Int
  gamesPlayed           Int
  regulationWins        Int
  overtimeWins          Int
  shootoutWins          Int
  regulationLosses      Int
  overtimeLosses        Int
  shootoutLosses        Int
  ties                  Int
  wins                  Int
  losses                Int
  goalsFor              Int
  goalsAgainst          Int
  goalDifference        Int
  points                Int
  pointsPercentage      Float
  qualified             Boolean
  tiebreakerSummaryText String   @default("")
  sourceSnapshotHash    String
  createdAt             DateTime @default(now())

  archive     CompetitionArchive @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  stage       ArchiveStage       @relation(fields: [archiveStageId], references: [id], onDelete: Restrict)
  participant ArchiveParticipant @relation(fields: [archiveParticipantId], references: [id], onDelete: Restrict)

  @@unique([archiveStageId, archiveParticipantId])
  @@unique([archiveStageId, rank])
  @@index([competitionArchiveId, rank])
}

model ArchiveTeamStat {
  id                       String   @id @default(cuid())
  competitionArchiveId     String
  archiveStageId           String
  archiveParticipantId     String
  gamesPlayed              Int
  goals                    Int
  goalsAgainst             Int
  shots                    Int
  shotAttempts             Int
  shootingPercentage       Float?
  saves                    Int      @default(0)
  savePercentage           Float?
  faceoffWins              Int      @default(0)
  faceoffPercentage        Float?
  possessionSeconds        Int      @default(0)
  possessionPercentage     Float?
  penalties                Int
  penaltyMinutes           Int
  powerPlayOpportunities   Int
  powerPlayGoals           Int
  powerPlayPercentage      Float?
  penaltyKillOpportunities Int      @default(0)
  penaltyKills             Int      @default(0)
  penaltyKillPercentage    Float?
  shortHandedGoals         Int
  wins                     Int      @default(0)
  losses                   Int      @default(0)
  overtimeLosses           Int      @default(0)
  seriesWins               Int      @default(0)
  seriesLosses             Int      @default(0)
  statsSnapshotText        String   @default("{}")
  sourceSnapshotHash       String
  createdAt                DateTime @default(now())

  archive     CompetitionArchive @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  stage       ArchiveStage       @relation(fields: [archiveStageId], references: [id], onDelete: Restrict)
  participant ArchiveParticipant @relation(fields: [archiveParticipantId], references: [id], onDelete: Restrict)

  @@unique([archiveStageId, archiveParticipantId])
  @@index([competitionArchiveId])
}

model ArchivePlayerStat {
  id                   String   @id @default(cuid())
  competitionArchiveId String
  archiveStageId       String
  sourcePlayerId       String
  sourceTeamId         String?
  archiveParticipantId String?
  playerNameSnapshot   String
  teamNameSnapshot     String?
  positionSnapshot     String
  isGoalie             Boolean  @default(false)
  gamesPlayed          Int
  goals                Int
  assists              Int
  points               Int
  shots                Int
  shotAttempts         Int      @default(0)
  shootingPercentage   Float?
  penaltyMinutes       Int
  powerPlayGoals       Int
  shortHandedGoals     Int
  shootoutAttempts     Int      @default(0)
  shootoutGoals        Int      @default(0)
  goalieWins           Int      @default(0)
  goalieLosses         Int      @default(0)
  overtimeLosses       Int      @default(0)
  shotsAgainst         Int      @default(0)
  saves                Int      @default(0)
  goalsAgainst         Int      @default(0)
  savePercentage       Float?
  shutouts             Int      @default(0)
  statsSnapshotText    String   @default("{}")
  sourceSnapshotHash   String
  createdAt            DateTime @default(now())

  archive     CompetitionArchive  @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  stage       ArchiveStage        @relation(fields: [archiveStageId], references: [id], onDelete: Restrict)
  participant ArchiveParticipant? @relation(fields: [archiveParticipantId], references: [id], onDelete: Restrict)

  @@unique([archiveStageId, sourcePlayerId])
  @@index([competitionArchiveId, isGoalie])
  @@index([competitionArchiveId, points])
  @@index([sourcePlayerId])
  @@index([sourceTeamId])
}

model ArchiveMatchSummary {
  id                       String    @id @default(cuid())
  competitionArchiveId     String
  archiveStageId           String
  sourceMatchId            String
  sourceCurrentResultId    String
  sourcePlayoffSeriesId    String?
  scheduleOrder            Int?
  roundNumber              Int?
  slotNumber               Int?
  gameNumber               Int?
  homeArchiveParticipantId String
  awayArchiveParticipantId String
  homeNameSnapshot         String
  awayNameSnapshot         String
  homeScore                Int
  awayScore                Int
  decisionType             String
  matchStatus              String
  seed                     String
  engineVersion            String
  balanceVersionSnapshot   String
  resultTraceHash          String
  completedAtSnapshot      DateTime?
  createdAt                DateTime  @default(now())

  archive CompetitionArchive @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  stage   ArchiveStage       @relation(fields: [archiveStageId], references: [id], onDelete: Restrict)
  home    ArchiveParticipant @relation("ArchiveMatchHome", fields: [homeArchiveParticipantId], references: [id], onDelete: Restrict)
  away    ArchiveParticipant @relation("ArchiveMatchAway", fields: [awayArchiveParticipantId], references: [id], onDelete: Restrict)

  @@unique([competitionArchiveId, sourceMatchId])
  @@index([archiveStageId, scheduleOrder])
  @@index([sourceMatchId])
  @@index([sourceCurrentResultId])
}

model ArchiveSeries {
  id                         String    @id @default(cuid())
  competitionArchiveId       String
  archiveStageId             String
  sourcePlayoffSeriesId      String
  roundNumber                Int
  roundNameSnapshot          String
  seriesOrder                Int
  bracketSlot                String
  participant1ArchiveId      String
  participant2ArchiveId      String
  participant1Seed           Int
  participant2Seed           Int
  participant1Wins           Int
  participant2Wins           Int
  winsRequired               Int
  winnerArchiveParticipantId String?
  homePatternSnapshotText    String
  status                     String
  startedAtSnapshot          DateTime?
  completedAtSnapshot        DateTime?
  createdAt                  DateTime  @default(now())

  archive      CompetitionArchive  @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  stage        ArchiveStage        @relation(fields: [archiveStageId], references: [id], onDelete: Restrict)
  participant1 ArchiveParticipant  @relation("ArchiveSeriesP1", fields: [participant1ArchiveId], references: [id], onDelete: Restrict)
  participant2 ArchiveParticipant  @relation("ArchiveSeriesP2", fields: [participant2ArchiveId], references: [id], onDelete: Restrict)
  winner       ArchiveParticipant? @relation("ArchiveSeriesWinner", fields: [winnerArchiveParticipantId], references: [id], onDelete: Restrict)
  games        ArchiveSeriesGame[]

  @@unique([competitionArchiveId, sourcePlayoffSeriesId])
  @@unique([archiveStageId, bracketSlot])
  @@index([archiveStageId, roundNumber, seriesOrder])
}

model ArchiveSeriesGame {
  id                       String    @id @default(cuid())
  archiveSeriesId          String
  sourceMatchId            String
  sourceCurrentResultId    String
  gameNumber               Int
  homeArchiveParticipantId String
  awayArchiveParticipantId String
  homeScore                Int
  awayScore                Int
  decisionType             String
  engineVersion            String
  balanceVersionIdSnapshot String?
  seed                     String
  traceHash                String
  completedAtSnapshot      DateTime?
  createdAt                DateTime  @default(now())

  series ArchiveSeries @relation(fields: [archiveSeriesId], references: [id], onDelete: Restrict)

  @@unique([archiveSeriesId, gameNumber])
  @@index([sourceMatchId])
}

model ArchiveAward {
  id                   String                    @id @default(cuid())
  competitionArchiveId String
  archiveStageId       String?
  awardType            ArchiveAwardType
  awardNameSnapshot    String
  recipientType        ArchiveAwardRecipientType
  archiveParticipantId String?
  sourcePlayerId       String?
  playerNameSnapshot   String?
  teamNameSnapshot     String?
  valueNumber          Float?
  valueText            String?
  rank                 Int
  shared               Boolean                   @default(false)
  criteriaSnapshotText String
  sourceSnapshotHash   String
  createdAt            DateTime                  @default(now())

  archive     CompetitionArchive  @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  stage       ArchiveStage?       @relation(fields: [archiveStageId], references: [id], onDelete: Restrict)
  participant ArchiveParticipant? @relation(fields: [archiveParticipantId], references: [id], onDelete: Restrict)

  @@index([competitionArchiveId, awardType])
  @@index([sourcePlayerId])
}

// ---------------------------------------------------------------------------
// F21 — Aggregated league simulation
// ---------------------------------------------------------------------------

enum AggregatedSeasonRunStatus {
  PREPARED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  SUPERSEDED
}

model AggregatedSeasonRun {
  id                   String                    @id @default(cuid())
  competitionEditionId String
  competitionStageId   String
  runVersion           Int
  status               AggregatedSeasonRunStatus @default(PREPARED)
  seed                 String
  configSnapshotText   String
  configHash           String
  inputSnapshotText    String
  inputHash            String
  balanceVersionId     String?
  balanceHash          String?
  scheduleHash         String
  resultHash           String?
  anomaliesText        String                    @default("[]")
  totalGames           Int                       @default(0)
  completedGames       Int                       @default(0)
  progress             Float                     @default(0)
  currentRound         Int?
  currentScheduleOrder Int?
  isCurrent            Boolean                   @default(false)
  supersedesRunId      String?
  supersededByRunId    String?
  errorMessage         String?
  startedAt            DateTime?
  completedAt          DateTime?
  failedAt             DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  edition CompetitionEdition       @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  stage   CompetitionStage         @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  matches AggregatedMatchSummary[]

  @@unique([competitionStageId, runVersion])
  @@index([competitionStageId, status])
  @@index([competitionStageId, isCurrent])
  @@index([inputHash])
  @@index([configHash])
  @@index([resultHash])
}

model AggregatedMatchSummary {
  id                           String    @id @default(cuid())
  competitionEditionId         String
  competitionStageId           String
  runId                        String
  scheduleKey                  String
  scheduleOrder                Int
  roundNumber                  Int
  slotNumber                   Int
  homeCompetitionParticipantId String
  awayCompetitionParticipantId String
  homeTeamNameSnapshot         String
  awayTeamNameSnapshot         String
  homeScore                    Int
  awayScore                    Int
  decisionType                 String
  homePoints                   Int
  awayPoints                   Int
  homeShots                    Int       @default(0)
  awayShots                    Int       @default(0)
  homeSaves                    Int       @default(0)
  awaySaves                    Int       @default(0)
  homePenalties                Int       @default(0)
  awayPenalties                Int       @default(0)
  homePim                      Int       @default(0)
  awayPim                      Int       @default(0)
  homePpOpportunities          Int       @default(0)
  awayPpOpportunities          Int       @default(0)
  homePpGoals                  Int       @default(0)
  awayPpGoals                  Int       @default(0)
  homePossessionEstimate       Float     @default(0.5)
  awayPossessionEstimate       Float     @default(0.5)
  seed                         String
  resultHash                   String
  completedAt                  DateTime?
  createdAt                    DateTime  @default(now())

  stage CompetitionStage    @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  run   AggregatedSeasonRun @relation(fields: [runId], references: [id], onDelete: Restrict)

  @@unique([runId, scheduleKey])
  @@index([competitionStageId, scheduleOrder])
  @@index([runId, scheduleOrder])
  @@index([resultHash])
}
