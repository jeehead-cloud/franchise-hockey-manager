generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// F1 bootstrap metadata + F3 world initialization state.
model AppMeta {
  id                     String    @id @default("default")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  /// True after a successful one-time world initialization.
  worldInitialized       Boolean   @default(false)
  worldDatasetId         String?
  worldInitializedAt     DateTime?
  worldSchemaVersion     Int?
  contractsInitializedAt DateTime?
}

