  createdAt                  DateTime  @default(now())

  archive      CompetitionArchive  @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  stage        ArchiveStage        @relation(fields: [archiveStageId], references: [id], onDelete: Restrict)
  participant1 ArchiveParticipant  @relation("ArchiveSeriesP1", fields: [participant1ArchiveId], references: [id], onDelete: Restrict)
  participant2 ArchiveParticipant  @relation("ArchiveSeriesP2", fields: [participant2ArchiveId], references: [id], onDelete: Restrict)
  winner       ArchiveParticipant? @relation("ArchiveSeriesWinner", fields: [winnerArchiveParticipantId], references: [id], onDelete: Restrict)
  games        ArchiveSeriesGame[]

  @@unique([competitionArchiveId, sourcePlayoffSeriesId])
  @@unique([archiveStageId, bracketSlot])
  @@index([archiveStageId, roundNumber, seriesOrder])
}

model ArchiveSeriesGame {
  id                       String    @id @default(cuid())
  archiveSeriesId          String
  sourceMatchId            String
  sourceCurrentResultId    String
  gameNumber               Int
  homeArchiveParticipantId String
  awayArchiveParticipantId String
  homeScore                Int
  awayScore                Int
  decisionType             String
  engineVersion            String
  balanceVersionIdSnapshot String?
  seed                     String
  traceHash                String
  completedAtSnapshot      DateTime?
  createdAt                DateTime  @default(now())

  series ArchiveSeries @relation(fields: [archiveSeriesId], references: [id], onDelete: Restrict)

  @@unique([archiveSeriesId, gameNumber])
  @@index([sourceMatchId])
}

model ArchiveAward {
  id                   String                    @id @default(cuid())
  competitionArchiveId String
  archiveStageId       String?
  awardType            ArchiveAwardType
  awardNameSnapshot    String
  recipientType        ArchiveAwardRecipientType
  archiveParticipantId String?
  sourcePlayerId       String?
  playerNameSnapshot   String?
  teamNameSnapshot     String?
  valueNumber          Float?
  valueText            String?
  rank                 Int
  shared               Boolean                   @default(false)
  criteriaSnapshotText String
  sourceSnapshotHash   String
  createdAt            DateTime                  @default(now())

  archive     CompetitionArchive  @relation(fields: [competitionArchiveId], references: [id], onDelete: Restrict)
  stage       ArchiveStage?       @relation(fields: [archiveStageId], references: [id], onDelete: Restrict)
  participant ArchiveParticipant? @relation(fields: [archiveParticipantId], references: [id], onDelete: Restrict)

  @@index([competitionArchiveId, awardType])
  @@index([sourcePlayerId])
}

// ---------------------------------------------------------------------------
// F21 — Aggregated league simulation
// ---------------------------------------------------------------------------

enum AggregatedSeasonRunStatus {
  PREPARED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  SUPERSEDED
}

model AggregatedSeasonRun {
  id                   String                    @id @default(cuid())
  competitionEditionId String
  competitionStageId   String
  runVersion           Int
  status               AggregatedSeasonRunStatus @default(PREPARED)
  seed                 String
  configSnapshotText   String
  configHash           String
  inputSnapshotText    String
  inputHash            String
  balanceVersionId     String?
  balanceHash          String?
  scheduleHash         String
  resultHash           String?
  anomaliesText        String                    @default("[]")
  totalGames           Int                       @default(0)
  completedGames       Int                       @default(0)
  progress             Float                     @default(0)
  currentRound         Int?
  currentScheduleOrder Int?
  isCurrent            Boolean                   @default(false)
  supersedesRunId      String?
  supersededByRunId    String?
  errorMessage         String?
  startedAt            DateTime?
  completedAt          DateTime?
  failedAt             DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  edition CompetitionEdition       @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  stage   CompetitionStage         @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  matches AggregatedMatchSummary[]

  @@unique([competitionStageId, runVersion])
  @@index([competitionStageId, status])
  @@index([competitionStageId, isCurrent])
  @@index([inputHash])
  @@index([configHash])
  @@index([resultHash])
}

model AggregatedMatchSummary {
  id                           String    @id @default(cuid())
  competitionEditionId         String
  competitionStageId           String
  runId                        String
  scheduleKey                  String
  scheduleOrder                Int
  roundNumber                  Int
  slotNumber                   Int
  homeCompetitionParticipantId String
  awayCompetitionParticipantId String
  homeTeamNameSnapshot         String
  awayTeamNameSnapshot         String
  homeScore                    Int
  awayScore                    Int
  decisionType                 String
  homePoints                   Int
  awayPoints                   Int
  homeShots                    Int       @default(0)
  awayShots                    Int       @default(0)
  homeSaves                    Int       @default(0)
  awaySaves                    Int       @default(0)
  homePenalties                Int       @default(0)
  awayPenalties                Int       @default(0)
  homePim                      Int       @default(0)
  awayPim                      Int       @default(0)
  homePpOpportunities          Int       @default(0)
  awayPpOpportunities          Int       @default(0)
  homePpGoals                  Int       @default(0)
  awayPpGoals                  Int       @default(0)
  homePossessionEstimate       Float     @default(0.5)
  awayPossessionEstimate       Float     @default(0.5)
  seed                         String
  resultHash                   String
  completedAt                  DateTime?
  createdAt                    DateTime  @default(now())

  stage CompetitionStage    @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  run   AggregatedSeasonRun @relation(fields: [runId], references: [id], onDelete: Restrict)

  @@unique([runId, scheduleKey])
  @@index([competitionStageId, scheduleOrder])
  @@index([runId, scheduleOrder])
  @@index([resultHash])
}

// ---------------------------------------------------------------------------
// F22 — National teams
// ---------------------------------------------------------------------------

enum NationalTeamCategory {
  SENIOR_MEN
  JUNIOR_U20
}

enum NationalTeamProfileStatus {
  ACTIVE
  INACTIVE
}

enum NationalTeamEditionStatus {
  PLANNED
  PREPARING
  READY
  LOCKED
  CANCELLED
}

enum NationalTeamEligibilityStatus {
  ELIGIBLE
  INELIGIBLE
  MANUALLY_EXCLUDED
}

enum NationalTeamRosterRole {
  FORWARD
  DEFENSE
  GOALIE
  RESERVE
}

enum NationalTeamCaptainRole {
  NONE
  CAPTAIN
  ALTERNATE
}

enum NationalTeamSelectionSource {
  SUGGESTED
  MANUAL
  IMPORTED
}

enum NationalTeamStaffRole {
  HEAD_COACH
  ASSISTANT_COACH
  GOALIE_COACH
}

enum NationalTeamLineUnitType {
  FORWARD_LINE
  DEFENSE_PAIR
  GOALIE
  PP
  PK
  OT
}

enum NationalTeamLineSlotType {
  LW
  C
  RW
  LD
  RD
  STARTER
  BACKUP
  THIRD
  F1
  F2
  F3
  D1
  D2
}

model NationalTeamProfile {
  id                     String                    @id @default(cuid())
  teamId                 String                    @unique
  countryId              String
  category               NationalTeamCategory
  displayName            String
  shortName              String?
  status                 NationalTeamProfileStatus @default(ACTIVE)
  defaultRosterRulesText String                    @default("{}")
  defaultTacticsText     String?
  externalId             String?
  sourceDataset          String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  team     Team                  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  country  Country               @relation(fields: [countryId], references: [id], onDelete: Restrict)
  editions NationalTeamEdition[]

  @@unique([countryId, category])
  @@unique([sourceDataset, externalId])
  @@index([category])
  @@index([status])
}

model NationalTeamEdition {
  id                       String                    @id @default(cuid())
  nationalTeamProfileId    String
  competitionEditionId     String
  competitionParticipantId String                    @unique
  status                   NationalTeamEditionStatus @default(PLANNED)
  teamNameSnapshot         String
  shortNameSnapshot        String?
  countryNameSnapshot      String
  rosterRulesSnapshotText  String                    @default("{}")
  rosterRulesHash          String                    @default("")
  eligibilitySnapshotText  String                    @default("{}")
  eligibilityHash          String                    @default("")
  tacticsSnapshotText      String?
  tacticsHash              String?
  rosterHash               String?
  lineupHash               String?
  preparedAt               DateTime?
  confirmedAt              DateTime?
  lockedAt                 DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  profile      NationalTeamProfile           @relation(fields: [nationalTeamProfileId], references: [id], onDelete: Restrict)
  edition      CompetitionEdition            @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  participant  CompetitionParticipant        @relation(fields: [competitionParticipantId], references: [id], onDelete: Restrict)
  candidates   NationalTeamCandidate[]
  roster       NationalTeamRosterPlayer[]
  staff        NationalTeamStaffAssignment[]
  tactics      NationalTeamTactics?
  lineup       NationalTeamLineup?
  medalResults TournamentMedalResult[]

  @@unique([nationalTeamProfileId, competitionEditionId])
  @@index([competitionEditionId, status])
  @@index([status])
}

model NationalTeamCandidate {
  id                    String                        @id @default(cuid())
  nationalTeamEditionId String
  sourcePlayerId        String
  playerNameSnapshot    String
  birthDateSnapshot     DateTime?
  positionSnapshot      String
  clubTeamIdSnapshot    String?
  clubNameSnapshot      String?
  eligibilityStatus     NationalTeamEligibilityStatus
  eligibilityReasonText String                        @default("")
  rankingScore          Float?
  rankingOrder          Int?
  selected              Boolean                       @default(false)
  generatedAt           DateTime                      @default(now())
  inputHash             String
  createdAt             DateTime                      @default(now())

  edition NationalTeamEdition @relation(fields: [nationalTeamEditionId], references: [id], onDelete: Restrict)

  @@unique([nationalTeamEditionId, sourcePlayerId])
  @@index([nationalTeamEditionId, eligibilityStatus])
  @@index([sourcePlayerId])
  @@index([rankingOrder])
}

model NationalTeamRosterPlayer {
  id                    String                      @id @default(cuid())
  nationalTeamEditionId String
  sourcePlayerId        String
  playerNameSnapshot    String
  clubTeamIdSnapshot    String?
  clubNameSnapshot      String?
  positionSnapshot      String
  rosterRole            NationalTeamRosterRole
  rosterOrder           Int
  jerseyNumber          Int?
  captainRole           NationalTeamCaptainRole     @default(NONE)
  selectionSource       NationalTeamSelectionSource @default(MANUAL)
  eligibilityHash       String                      @default("")
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  edition NationalTeamEdition @relation(fields: [nationalTeamEditionId], references: [id], onDelete: Restrict)

  @@unique([nationalTeamEditionId, sourcePlayerId])
  @@unique([nationalTeamEditionId, rosterRole, rosterOrder])
  @@index([nationalTeamEditionId, rosterRole])
  @@index([sourcePlayerId])
}

model NationalTeamStaffAssignment {
  id                    String                @id @default(cuid())
  nationalTeamEditionId String
  sourceCoachId         String
  coachNameSnapshot     String
  role                  NationalTeamStaffRole
  assignmentOrder       Int                   @default(1)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  edition NationalTeamEdition @relation(fields: [nationalTeamEditionId], references: [id], onDelete: Restrict)

  @@unique([nationalTeamEditionId, role, assignmentOrder])
  @@index([nationalTeamEditionId])
  @@index([sourceCoachId])
}

model NationalTeamTactics {
  id                    String        @id @default(cuid())
  nationalTeamEditionId String        @unique
  tacticalStyle         TacticalStyle
  tacticsText           String        @default("{}")
  tacticsHash           String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  edition NationalTeamEdition @relation(fields: [nationalTeamEditionId], references: [id], onDelete: Restrict)
}

model NationalTeamLineup {
  id                    String   @id @default(cuid())
  nationalTeamEditionId String   @unique
  status                String   @default("DRAFT")
  generatedBy           String   @default("MANUAL")
  rosterHash            String
  lineupHash            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  edition NationalTeamEdition      @relation(fields: [nationalTeamEditionId], references: [id], onDelete: Restrict)
  slots   NationalTeamLineupSlot[]
}

model NationalTeamLineupSlot {
  id                   String                   @id @default(cuid())
  nationalTeamLineupId String
  unitType             NationalTeamLineUnitType
  unitNumber           Int
  slotType             NationalTeamLineSlotType
  sourcePlayerId       String
  playerNameSnapshot   String
  positionSnapshot     String
  slotOrder            Int
  createdAt            DateTime                 @default(now())

  lineup NationalTeamLineup @relation(fields: [nationalTeamLineupId], references: [id], onDelete: Restrict)

  @@unique([nationalTeamLineupId, unitType, unitNumber, slotType])
  @@index([nationalTeamLineupId, slotOrder])
  @@index([sourcePlayerId])
}

// ---------------------------------------------------------------------------
// F23 — International tournament medals
// ---------------------------------------------------------------------------

enum TournamentMedalType {
  GOLD
  SILVER
  BRONZE
}

model TournamentMedalResult {
  id                       String              @id @default(cuid())
  competitionEditionId     String
  competitionStageId       String?
  medalType                TournamentMedalType
  competitionParticipantId String
  nationalTeamEditionId    String?
  teamNameSnapshot         String
  countryNameSnapshot      String
  sourceMatchId            String?
  finalPlacement           Int
  resultHash               String
  createdAt                DateTime            @default(now())

  edition             CompetitionEdition   @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  stage               CompetitionStage?    @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  nationalTeamEdition NationalTeamEdition? @relation(fields: [nationalTeamEditionId], references: [id], onDelete: Restrict)
  sourceMatch         Match?               @relation(fields: [sourceMatchId], references: [id], onDelete: Restrict)

  @@unique([competitionEditionId, medalType])
  @@unique([competitionEditionId, competitionParticipantId])
  @@index([competitionEditionId])
  @@index([competitionStageId])
  @@index([competitionParticipantId])
  @@index([nationalTeamEditionId])
  @@index([sourceMatchId])
  @@index([medalType])
}

// ---------------------------------------------------------------------------
// F24 — Player development configuration, runs, snapshots
// ---------------------------------------------------------------------------

enum PlayerDevelopmentRunStatus {
  PREPARED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  SUPERSEDED
}

enum PlayerDevelopmentOutcome {
  DEVELOPED
  DECLINED
  STABLE
  RETIRED
}

enum PlayerSeasonSnapshotType {
  PRE_DEVELOPMENT
  POST_DEVELOPMENT
}

/// Named development preset (system default or user duplicate). F24.
model PlayerDevelopmentPreset {
  id          String                           @id @default(cuid())
  name        String                           @unique
  description String?
  isSystem    Boolean                          @default(false)
  createdAt   DateTime                         @default(now())
  updatedAt   DateTime                         @updatedAt
  versions    PlayerDevelopmentPresetVersion[]
}

/// Immutable development configuration snapshot. F24.
model PlayerDevelopmentPresetVersion {
  id              String                                @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                              @default(now())
  createdBySource CommissionerAuditSource?
  preset          PlayerDevelopmentPreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor       ActivePlayerDevelopmentConfiguration?
  runs            PlayerDevelopmentRun[]

  @@unique([presetId, versionNumber])
  @@index([configHash])
  @@index([presetId, createdAt])
}

/// Singleton active development version. F24.
model ActivePlayerDevelopmentConfiguration {
  id                    String                         @id @default("default")
  activePresetVersionId String                         @unique
  updatedAt             DateTime                       @updatedAt
  activeVersion         PlayerDevelopmentPresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}

/// Official annual development run per WorldSeason. F24.
model PlayerDevelopmentRun {
  id              String                     @id @default(cuid())
  worldSeasonId   String
  status          PlayerDevelopmentRunStatus @default(PREPARED)
  runVersion      Int
  effectiveDate   String
  baseSeed        String
  configVersionId String
  configHash      String
  inputHash       String
  resultHash      String?
  totalPlayers    Int                        @default(0)
  developedCount  Int                        @default(0)
  declinedCount   Int                        @default(0)
  stableCount     Int                        @default(0)
  retiredCount    Int                        @default(0)
  warningCount    Int                        @default(0)
  isCurrent       Boolean                    @default(false)
  backupPath      String?
  failureReason   String?
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  worldSeason   WorldSeason                    @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  configVersion PlayerDevelopmentPresetVersion @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  results       PlayerDevelopmentResult[]
  snapshots     PlayerSeasonSnapshot[]

  @@unique([worldSeasonId, runVersion])
  @@index([worldSeasonId, status])
  @@index([worldSeasonId, isCurrent])
  @@index([inputHash])
  @@index([configHash])
  @@index([resultHash])
}

/// Per-player outcome for a development run. F24.
model PlayerDevelopmentResult {
  id                   String                   @id @default(cuid())
  runId                String
  playerId             String
  playerNameSnapshot   String
  playerType           String
  positionSnapshot     String
  teamIdSnapshot       String?
  teamNameSnapshot     String?
  ageBefore            Int?
  ageOnEffectiveDate   Int
  lifecycleBefore      String
  lifecycleAfter       String
  currentAbilityBefore Float
  currentAbilityAfter  Float
  potentialSnapshot    Int
  roleBefore           String
  roleAfter            String
  formBefore           Int
  formAfter            Int
  developmentBudget    Float
  usedBudget           Float
  unusedBudget         Float
  outcome              PlayerDevelopmentOutcome
  retired              Boolean
  retirementReasonText String?
  attributeChangesText String
  diagnosticsText      String
  inputHash            String
  resultHash           String
  createdAt            DateTime                 @default(now())

  run    PlayerDevelopmentRun @relation(fields: [runId], references: [id], onDelete: Restrict)
  player Player               @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([runId, playerId])
  @@index([runId, outcome])
  @@index([playerId])
}

/// Immutable player model snapshot before/after development. F24.
model PlayerSeasonSnapshot {
  id                      String                   @id @default(cuid())
  playerId                String
  worldSeasonId           String
  runId                   String
  snapshotType            PlayerSeasonSnapshotType
  snapshotDate            String
  playerNameSnapshot      String
  teamIdSnapshot          String?
  teamNameSnapshot        String?
  playerStatusSnapshot    String
  positionSnapshot        String
  roleSnapshot            String?
  currentAbilitySnapshot  Float?
  potentialSnapshot       Int?
  formSnapshot            Int
  attributesText          String
  attributesHash          String
  playerUpdatedAtSnapshot DateTime
  inputHash               String
  createdAt               DateTime                 @default(now())

  player      Player               @relation(fields: [playerId], references: [id], onDelete: Restrict)
  run         PlayerDevelopmentRun @relation(fields: [runId], references: [id], onDelete: Restrict)
  worldSeason WorldSeason          @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)

  @@unique([playerId, runId, snapshotType])
  @@index([playerId, worldSeasonId])
  @@index([runId, snapshotType])
}

// ---------------------------------------------------------------------------
// F25 — Youth generation profiles, name pools, runs, cohorts, provenance
// ---------------------------------------------------------------------------

enum YouthGenerationRunStatus {
  PREPARED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  SUPERSEDED
}

enum YouthQualityTier {
  ELITE
  HIGH
  AVERAGE
  LOW
  LONG_SHOT
}

model YouthGenerationProfileSet {
  id          String                             @id @default(cuid())
  name        String                             @unique
  description String?
  isSystem    Boolean                            @default(false)
  createdAt   DateTime                           @default(now())
  updatedAt   DateTime                           @updatedAt
  versions    YouthGenerationProfileSetVersion[]
}

model YouthGenerationProfileSetVersion {
  id              String                              @id @default(cuid())
  profileSetId    String
  versionNumber   Int
  schemaVersion   Int
  configHash      String
  changeReason    String
  createdAt       DateTime                            @default(now())
  createdBySource CommissionerAuditSource?
  profileSet      YouthGenerationProfileSet           @relation(fields: [profileSetId], references: [id], onDelete: Restrict)
  countryProfiles CountryYouthProfileVersion[]
  activeFor       ActiveYouthGenerationConfiguration?
  runs            YouthGenerationRun[]

  @@unique([profileSetId, versionNumber])
  @@index([configHash])
  @@index([profileSetId, createdAt])
}

model ActiveYouthGenerationConfiguration {
  id                        String                           @id @default("default")
  activeProfileSetVersionId String                           @unique
  updatedAt                 DateTime                         @updatedAt
  activeVersion             YouthGenerationProfileSetVersion @relation(fields: [activeProfileSetVersionId], references: [id], onDelete: Restrict)
}

model CountryYouthProfileVersion {
  id                  String                           @id @default(cuid())
  profileSetVersionId String
  countryId           String
  profileText         String
  profileHash         String
  namePoolVersionId   String
  createdAt           DateTime                         @default(now())
  profileSetVersion   YouthGenerationProfileSetVersion @relation(fields: [profileSetVersionId], references: [id], onDelete: Restrict)
  country             Country                          @relation(fields: [countryId], references: [id], onDelete: Restrict)
  namePoolVersion     CountryNamePoolVersion           @relation(fields: [namePoolVersionId], references: [id], onDelete: Restrict)

  @@unique([profileSetVersionId, countryId])
  @@index([countryId])
  @@index([profileHash])
  @@index([namePoolVersionId])
}

model CountryNamePool {
  id        String                   @id @default(cuid())
  countryId String
  name      String
  isSystem  Boolean                  @default(false)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  country   Country                  @relation(fields: [countryId], references: [id], onDelete: Restrict)
  versions  CountryNamePoolVersion[]

  @@unique([countryId, name])
  @@index([countryId])
}

model CountryNamePoolVersion {
  id                 String                       @id @default(cuid())
  namePoolId         String
  versionNumber      Int
  maleFirstNamesText String
  lastNamesText      String
  firstNameCount     Int
  lastNameCount      Int
  poolHash           String
  changeReason       String
  createdAt          DateTime                     @default(now())
  createdBySource    CommissionerAuditSource?
  namePool           CountryNamePool              @relation(fields: [namePoolId], references: [id], onDelete: Restrict)
  countryProfiles    CountryYouthProfileVersion[]
  cohorts            YouthCohort[]

  @@unique([namePoolId, versionNumber])
  @@index([poolHash])
  @@index([namePoolId, createdAt])
}

model YouthGenerationRun {
  id                    String                   @id @default(cuid())
  worldSeasonId         String
  status                YouthGenerationRunStatus @default(PREPARED)
  runVersion            Int                      @default(1)
  referenceDate         String
  baseSeed              String
  profileSetVersionId   String
  profileSetHash        String
  inputHash             String
  resultHash            String?
  countryCount          Int                      @default(0)
  enabledCountryCount   Int                      @default(0)
  totalPlannedPlayers   Int                      @default(0)
  totalGeneratedPlayers Int                      @default(0)
  warningCount          Int                      @default(0)
  isCurrent             Boolean                  @default(false)
  backupPath            String?
  failureReason         String?
  plannedInputText      String?
  startedAt             DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  worldSeason       WorldSeason                      @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  profileSetVersion YouthGenerationProfileSetVersion @relation(fields: [profileSetVersionId], references: [id], onDelete: Restrict)
  cohorts           YouthCohort[]
  generatedPlayers  YouthGeneratedPlayer[]

  @@index([worldSeasonId, status])
  @@index([worldSeasonId, isCurrent])
  @@index([status])
}

model YouthCohort {
  id                   String   @id @default(cuid())
  youthGenerationRunId String
  worldSeasonId        String
  countryId            String
  countryNameSnapshot  String
  referenceDate        String
  cohortOrder          Int
  profileHash          String
  namePoolVersionId    String
  namePoolHash         String
  plannedSize          Int
  generatedSize        Int
  age15Count           Int
  age16Count           Int
  age17Count           Int
  skaterCount          Int
  goalieCount          Int
  cohortHash           String
  createdAt            DateTime @default(now())

  run             YouthGenerationRun     @relation(fields: [youthGenerationRunId], references: [id], onDelete: Restrict)
  worldSeason     WorldSeason            @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  country         Country                @relation(fields: [countryId], references: [id], onDelete: Restrict)
  namePoolVersion CountryNamePoolVersion @relation(fields: [namePoolVersionId], references: [id], onDelete: Restrict)
  players         YouthGeneratedPlayer[]

  @@unique([youthGenerationRunId, countryId])
  @@index([worldSeasonId])
  @@index([countryId])
  @@index([youthGenerationRunId, cohortOrder])
}

model YouthGeneratedPlayer {
  id                      String           @id @default(cuid())
  youthGenerationRunId    String
  youthCohortId           String
  playerId                String           @unique
  generationIndex         Int
  countryId               String
  playerNameSnapshot      String
  dateOfBirthSnapshot     String
  ageOnReferenceDate      Int
  positionSnapshot        String
  qualityTier             YouthQualityTier
  currentAbilitySnapshot  Float
  potentialSnapshot       Int
  developmentRateSnapshot Float
  roleSnapshot            String
  heightCmSnapshot        Int?
  weightKgSnapshot        Int?
  shootsSnapshot          String?
  generationHash          String
  diagnosticsText         String?
  createdAt               DateTime         @default(now())

  run     YouthGenerationRun @relation(fields: [youthGenerationRunId], references: [id], onDelete: Restrict)
  cohort  YouthCohort        @relation(fields: [youthCohortId], references: [id], onDelete: Restrict)
  player  Player             @relation(fields: [playerId], references: [id], onDelete: Restrict)
  country Country            @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@unique([youthGenerationRunId, playerId])
  @@unique([youthCohortId, generationIndex])
  @@index([youthGenerationRunId])
  @@index([countryId])
  @@index([generationHash])
}

// ---------------------------------------------------------------------------
// F26 — Team scouting
// ---------------------------------------------------------------------------

enum ScoutingAssignmentTargetType {
  PLAYER
  COUNTRY
  WATCHLIST
}

enum ScoutingAssignmentStatus {
  PREPARED
  COMPLETED
  CANCELLED
}

enum ScoutingDepartmentScoutRole {
  PRIMARY
  ASSISTANT
}

enum ScoutStatus {
  ACTIVE
  INACTIVE
  RETIRED
}

enum ScoutSourceType {
  COMMISSIONER
  IMPORTED
}

/// Named, versioned calibration for deterministic scouting observations.
model ScoutingPreset {
  id          String                  @id @default(cuid())
  name        String                  @unique
  description String?
  isSystem    Boolean                 @default(false)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  versions    ScoutingPresetVersion[]
}

model ScoutingPresetVersion {
  id              String                       @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                     @default(now())
  createdBySource CommissionerAuditSource?
  preset          ScoutingPreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor       ActiveScoutingConfiguration?
  assignments     ScoutingAssignment[]

  @@unique([presetId, versionNumber])
  @@index([configHash])
}

model ActiveScoutingConfiguration {
  id                    String                @id @default("default")
  activePresetVersionId String                @unique
  updatedAt             DateTime              @updatedAt
  activeVersion         ScoutingPresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}

/// Commissioner-managed scout; never automatically generated by bootstrap.
model Scout {
  id                      String                    @id @default(cuid())
  firstName               String
  lastName                String
  status                  ScoutStatus               @default(ACTIVE)
  sourceType              ScoutSourceType           @default(COMMISSIONER)
  createdBySource         CommissionerAuditSource?
  evaluatingRating        Int
  potentialRating         Int
  skaterRating            Int
  goalieRating            Int
  specialtiesJson         String                    @default("[]")
  countryFamiliarityJson  String                    @default("{}")
  positionFamiliarityJson String                    @default("{}")
  persistentBias          Float                     @default(0)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  departmentAssignments   ScoutingDepartmentScout[]
  assignmentScouts        ScoutingAssignmentScout[]
  observations            ScoutingObservation[]

  @@index([status])
}

/// One optional scouting department per club team.
model ScoutingDepartment {
  id        String                    @id @default(cuid())
  teamId    String                    @unique
  name      String
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  team      Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scouts    ScoutingDepartmentScout[]
}

model ScoutingDepartmentScout {
  id           String                      @id @default(cuid())
  departmentId String
  scoutId      String
  role         ScoutingDepartmentScoutRole @default(ASSISTANT)
  createdAt    DateTime                    @default(now())
  department   ScoutingDepartment          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  scout        Scout                       @relation(fields: [scoutId], references: [id], onDelete: Restrict)

  @@unique([departmentId, scoutId])
  @@index([scoutId])
}

/// Team-private index for a prospect's immutable scouting history.
model TeamProspectKnowledge {
  id              String               @id @default(cuid())
  teamId          String
  playerId        String
  currentReportId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  team            Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player          Player               @relation(fields: [playerId], references: [id], onDelete: Restrict)
  reports         TeamScoutingReport[]

  @@unique([teamId, playerId])
  @@index([playerId])
}

/// Prepared assignment freezes target player IDs and active calibration version.
model ScoutingAssignment {
  id              String                       @id @default(cuid())
  teamId          String
  targetType      ScoutingAssignmentTargetType
  targetJson      String
  observedOn      String
  durationDays    Int
  seed            String
  status          ScoutingAssignmentStatus     @default(PREPARED)
  configVersionId String
  configHash      String
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  team            Team                         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  configVersion   ScoutingPresetVersion        @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  scouts          ScoutingAssignmentScout[]
  observations    ScoutingObservation[]

  @@index([teamId, status])
  @@index([configVersionId])
}

model ScoutingAssignmentScout {
  id           String             @id @default(cuid())
  assignmentId String
  scoutId      String
  createdAt    DateTime           @default(now())
  assignment   ScoutingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  scout        Scout              @relation(fields: [scoutId], references: [id], onDelete: Restrict)

  @@unique([assignmentId, scoutId])
  @@index([scoutId])
}

/// Immutable engine output. JSON contains estimates only, never player truth.
model ScoutingObservation {
  id                    String             @id @default(cuid())
  teamId                String
  playerId              String
  scoutId               String
  assignmentId          String
  observationId         String             @unique
  observationJson       String
  sourcePlayerStateHash String
  observedOn            String
  durationDays          Int
  createdAt             DateTime           @default(now())
  team                  Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player                Player             @relation(fields: [playerId], references: [id], onDelete: Restrict)
  scout                 Scout              @relation(fields: [scoutId], references: [id], onDelete: Restrict)
  assignment            ScoutingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, scoutId, playerId])
  @@index([teamId, playerId])
  @@index([assignmentId])
}

/// Append-only consolidated report. Current report is derived by highest version.
model TeamScoutingReport {
  id                    String                @id @default(cuid())
  knowledgeId           String
  teamId                String
  playerId              String
  versionNumber         Int
  reportJson            String
  reportHash            String
  sourcePlayerStateHash String
  createdAt             DateTime              @default(now())
  knowledge             TeamProspectKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  team                  Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player                Player                @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([knowledgeId, versionNumber])
  @@index([teamId, playerId, createdAt])
  @@index([reportHash])
}

model TeamProspectWatchlistEntry {
  id             String   @id @default(cuid())
  teamId         String
  playerId       String
  manualPriority Int      @default(0)
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([teamId, playerId])
  @@index([teamId, manualPriority])
}

// ---------------------------------------------------------------------------
// F27 — NHL Draft
// ---------------------------------------------------------------------------

enum DraftEventStatus {
  PLANNED
  PREPARING
  READY
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DraftEligibleStatus {
  AVAILABLE
  DRAFTED
  WITHDRAWN
  INELIGIBLE_AFTER_REVIEW
}

enum DraftPickStatus {
  PENDING
  ON_THE_CLOCK
  COMPLETED
  PASSED
  CANCELLED
}

enum DraftSelectionSource {
  MANUAL
  AUTO
  COMMISSIONER_CORRECTION
}

enum PlayerDraftRightStatus {
  ACTIVE
  RENOUNCED
  EXPIRED
  CONVERTED_TO_CONTRACT
}

/// Named, versioned draft configuration preset (separate from F10/F24/F25/F26 presets).
model DraftPreset {
  id          String               @id @default(cuid())
  name        String               @unique
  description String?
  isSystem    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  versions    DraftPresetVersion[]
}

model DraftPresetVersion {
  id              String                    @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                  @default(now())
  createdBySource CommissionerAuditSource?
  preset          DraftPreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor       ActiveDraftConfiguration?
  draftEvents     DraftEvent[]

  @@unique([presetId, versionNumber])
  @@index([configHash])
}

model ActiveDraftConfiguration {
  id                    String             @id @default("default")
  activePresetVersionId String             @unique
  updatedAt             DateTime           @updatedAt
  activeVersion         DraftPresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}

/// One annual amateur draft for a WorldSeason.
model DraftEvent {
  id                 String           @id @default(cuid())
  worldSeasonId      String
  name               String
  status             DraftEventStatus @default(PLANNED)
  presetVersionId    String
  configHash         String
  cutoffDate         String
  baseSeed           String
  eligibilityHash    String?
  initialOrderHash   String?
  lotteryHash        String?
  finalOrderHash     String?
  currentOverallPick Int              @default(0)
  totalRounds        Int
  totalPicks         Int              @default(0)
  startedAt          DateTime?
  completedAt        DateTime?
  resultHash         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  worldSeason       WorldSeason              @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  presetVersion     DraftPresetVersion       @relation(fields: [presetVersionId], references: [id], onDelete: Restrict)
  eligiblePlayers   DraftEligiblePlayer[]
  teamEntries       DraftTeamEntry[]
  lotteryDraws      DraftLotteryDraw[]
  picks             DraftPick[]
  boardSnapshots    DraftTeamBoardSnapshot[]
  playerDraftRights PlayerDraftRight[]

  @@unique([worldSeasonId, name])
  @@index([worldSeasonId, status])
  @@index([status])
}

/// Frozen eligibility snapshot. No true potential stored.
model DraftEligiblePlayer {
  id                 String              @id @default(cuid())
  draftEventId       String
  playerId           String
  playerNameSnapshot String
  birthDateSnapshot  String
  ageOnCutoffDate    Int
  countrySnapshot    String?
  positionSnapshot   String?
  lifecycleSnapshot  String
  sourceTypeSnapshot String
  eligibilityHash    String
  status             DraftEligibleStatus @default(AVAILABLE)
  createdAt          DateTime            @default(now())

  draftEvent DraftEvent  @relation(fields: [draftEventId], references: [id], onDelete: Cascade)
  player     Player      @relation(fields: [playerId], references: [id], onDelete: Restrict)
  picks      DraftPick[]

  @@unique([draftEventId, playerId])
  @@index([draftEventId, status])
  @@index([playerId])
}

/// Participating team entry (order snapshots). currentTeamId == originalTeamId in F27 (no pick trades).
model DraftTeamEntry {
  id                    String   @id @default(cuid())
  draftEventId          String
  teamId                String
  teamNameSnapshot      String
  originalOrderPosition Int
  lotteryOrderPosition  Int?
  finalOrderPosition    Int?
  sourceStandingRank    Int?
  createdAt             DateTime @default(now())

  draftEvent DraftEvent @relation(fields: [draftEventId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([draftEventId, teamId])
  @@index([draftEventId, finalOrderPosition])
  @@index([teamId])
}

/// Persisted lottery draw (deterministic, seeded).
model DraftLotteryDraw {
  id               String   @id @default(cuid())
  draftEventId     String
  drawNumber       Int
  winningTeamId    String
  originalPosition Int
  newPosition      Int
  weightSnapshot   Float
  seedFragment     String
  drawHash         String
  createdAt        DateTime @default(now())

  draftEvent DraftEvent @relation(fields: [draftEventId], references: [id], onDelete: Cascade)

  @@unique([draftEventId, drawNumber])
  @@index([draftEventId])
}

/// One draft slot per (event, overall pick). `currentTeamId` equals `originalTeamId` in F27.
model DraftPick {
  id                         String                @id @default(cuid())
  draftEventId               String
  roundNumber                Int
  pickInRound                Int
  overallPick                Int
  originalTeamId             String
  currentTeamId              String
  teamNameSnapshot           String
  status                     DraftPickStatus       @default(PENDING)
  selectedPlayerId           String?
  selectedPlayerNameSnapshot String?
  selectedAt                 DateTime?
  selectionSource            DraftSelectionSource?
  scoutingReportId           String?
  teamBoardSnapshotText      String?
  pickHash                   String?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  draftEvent           DraftEvent            @relation(fields: [draftEventId], references: [id], onDelete: Cascade)
  originalTeam         Team                  @relation("DraftPickOriginalTeam", fields: [originalTeamId], references: [id], onDelete: Restrict)
  currentTeam          Team                  @relation("DraftPickCurrentTeam", fields: [currentTeamId], references: [id], onDelete: Restrict)
  selectedPlayer       DraftEligiblePlayer?  @relation(fields: [selectedPlayerId], references: [id], onDelete: SetNull)
  draftRight           PlayerDraftRight?
  /// F29 — pick transfer history (does not rewrite original/current ownership).
  tradeProposalAssets  TradeProposalAsset[]
  completedTradeAssets CompletedTradeAsset[]
  tradeTransactions    TradeTransaction[]

  @@unique([draftEventId, overallPick])
  @@unique([draftEventId, roundNumber, pickInRound])
  @@unique([draftEventId, selectedPlayerId])
  @@index([draftEventId, currentTeamId, status])
  @@index([draftEventId, status])
  @@index([currentTeamId])
}

/// Draft rights — created ACTIVE only in F27. No contract; no club assignment.
model PlayerDraftRight {
  id                 String                 @id @default(cuid())
  playerId           String
  teamId             String
  draftEventId       String
  draftPickId        String                 @unique
  status             PlayerDraftRightStatus @default(ACTIVE)
  acquiredAt         DateTime               @default(now())
  expiresAt          DateTime?
  playerNameSnapshot String
  teamNameSnapshot   String
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  player               Player                @relation(fields: [playerId], references: [id], onDelete: Restrict)
  team                 Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  draftEvent           DraftEvent            @relation(fields: [draftEventId], references: [id], onDelete: Restrict)
  draftPick            DraftPick             @relation(fields: [draftPickId], references: [id], onDelete: Restrict)
  originatingContract  PlayerContract?
  contractOffers       ContractOffer[]
  contractTransactions ContractTransaction[]
  /// F29 — draft-right transfer history (does not rewrite DraftPick/DraftEvent history).
  tradeProposalAssets  TradeProposalAsset[]
  completedTradeAssets CompletedTradeAsset[]
  tradeTransactions    TradeTransaction[]

  @@unique([playerId, status])
  @@index([playerId, status])
  @@index([teamId, status])
  @@index([draftEventId])
}

/// Frozen team board snapshot at draft start (estimates only — no truth).
model DraftTeamBoardSnapshot {
  id           String   @id @default(cuid())
  draftEventId String
  teamId       String
  boardText    String
  boardHash    String
  createdAt    DateTime @default(now())

  draftEvent DraftEvent @relation(fields: [draftEventId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([draftEventId, teamId])
  @@index([teamId])
}

// ---------------------------------------------------------------------------
// Contracts and free agency (F28)
// ---------------------------------------------------------------------------

enum ContractStatus {
  FUTURE
  ACTIVE
  EXPIRED
  TERMINATED
  CANCELLED
}

enum ContractType {
  STANDARD
  ENTRY
}

enum ContractSource {
  INITIAL_IMPORT
  EXTENSION
  FREE_AGENT
  DRAFT_RIGHTS
  COMMISSIONER
}

enum ContractOfferType {
  EXTENSION
  FREE_AGENT
  DRAFT_RIGHTS
}

enum ContractOfferStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum ContractRecommendationType {
  RECOMMEND_EXTEND
  RECOMMEND_RELEASE
  REVIEW
}

enum ContractTransactionType {
  INITIAL_CONTRACT
  EXTENSION_SIGNED
  FREE_AGENT_SIGNED
  DRAFT_RIGHTS_SIGNED
  CONTRACT_EXPIRED
  FUTURE_CONTRACT_ACTIVATED
  PLAYER_RELEASED
  OFFER_REJECTED
  OFFER_WITHDRAWN
}

enum ContractExpirationRunStatus {
  PREPARED
  COMPLETED
  FAILED
  CANCELLED
}

enum ContractInitializationRunStatus {
  PREPARED
  COMPLETED
  FAILED
  CANCELLED
}

model ContractPreset {
  id          String                  @id @default(cuid())
  name        String                  @unique
  description String?
  isSystem    Boolean                 @default(false)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  versions    ContractPresetVersion[]
}

model ContractPresetVersion {
  id                 String                       @id @default(cuid())
  presetId           String
  versionNumber      Int
  schemaVersion      Int
  configJson         String
  configHash         String
  changeReason       String
  createdAt          DateTime                     @default(now())
  createdBySource    CommissionerAuditSource?
  preset             ContractPreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor          ActiveContractConfiguration?
  contracts          PlayerContract[]
  offers             ContractOffer[]
  recommendations    ContractRecommendation[]
  initializationRuns ContractInitializationRun[]
  expirationRuns     ContractExpirationRun[]

  @@unique([presetId, versionNumber])
  @@index([configHash])
}

model ActiveContractConfiguration {
  id                    String                @id @default("default")
  activePresetVersionId String                @unique
  updatedAt             DateTime              @updatedAt
  activeVersion         ContractPresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}

model PlayerContract {
  id                       String                   @id @default(cuid())
  playerId                 String
  teamId                   String
  startWorldSeasonId       String
  endWorldSeasonId         String
  startSeasonOrderSnapshot Int
  endSeasonOrderSnapshot   Int
  annualSalary             Int
  status                   ContractStatus
  contractType             ContractType
  source                   ContractSource
  signedAt                 DateTime                 @default(now())
  activatedAt              DateTime?
  expiredAt                DateTime?
  terminatedAt             DateTime?
  supersedesContractId     String?
  originatingOfferId       String?                  @unique
  originatingDraftRightId  String?                  @unique
  configVersionId          String
  configHash               String
  playerNameSnapshot       String
  teamNameSnapshot         String
  termsHash                String
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  player                   Player                   @relation(fields: [playerId], references: [id], onDelete: Restrict)
  team                     Team                     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  startWorldSeason         WorldSeason              @relation("ContractStartSeason", fields: [startWorldSeasonId], references: [id], onDelete: Restrict)
  endWorldSeason           WorldSeason              @relation("ContractEndSeason", fields: [endWorldSeasonId], references: [id], onDelete: Restrict)
  configVersion            ContractPresetVersion    @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  supersedesContract       PlayerContract?          @relation("ContractSupersession", fields: [supersedesContractId], references: [id], onDelete: Restrict)
  supersededBy             PlayerContract[]         @relation("ContractSupersession")
  originatingOffer         ContractOffer?           @relation("OfferResultingContract", fields: [originatingOfferId], references: [id], onDelete: Restrict)
  originatingDraftRight    PlayerDraftRight?        @relation(fields: [originatingDraftRightId], references: [id], onDelete: Restrict)
  extensionOffers          ContractOffer[]          @relation("OfferCurrentContract")
  recommendations          ContractRecommendation[]
  transactions             ContractTransaction[]
  /// F29 — set when an ACTIVE/FUTURE contract was moved (not created) by a completed trade.
  transferredByTradeId     String?
  transferredByTrade       CompletedTrade?          @relation("ContractsTransferredByTrade", fields: [transferredByTradeId], references: [id], onDelete: Restrict)
  tradeProposalAssets      TradeProposalAsset[]
  completedTradeAssets     CompletedTradeAsset[]
  tradeTransactions        TradeTransaction[]

  @@index([playerId, status])
  @@index([teamId, status, endSeasonOrderSnapshot])
  @@index([startWorldSeasonId])
  @@index([endWorldSeasonId])
  @@index([transferredByTradeId])
}

model ContractRecommendation {
  id                   String                     @id @default(cuid())
  playerId             String
  teamId               String
  currentContractId    String?
  recommendationType   ContractRecommendationType
  recommendedSalary    Int
  recommendedTermYears Int
  factorsText          String
  configVersionId      String
  configHash           String
  inputHash            String
  recommendationHash   String
  createdAt            DateTime                   @default(now())
  player               Player                     @relation(fields: [playerId], references: [id], onDelete: Restrict)
  team                 Team                       @relation(fields: [teamId], references: [id], onDelete: Restrict)
  currentContract      PlayerContract?            @relation(fields: [currentContractId], references: [id], onDelete: Restrict)
  configVersion        ContractPresetVersion      @relation(fields: [configVersionId], references: [id], onDelete: Restrict)

  @@index([playerId, teamId, createdAt])
}

model ContractOffer {
  id                   String                @id @default(cuid())
  playerId             String
  offeringTeamId       String
  offerType            ContractOfferType
  targetContractType   ContractType
  startWorldSeasonId   String
  endWorldSeasonId     String
  annualSalary         Int
  status               ContractOfferStatus   @default(DRAFT)
  currentContractId    String?
  draftRightId         String?
  configVersionId      String
  configHash           String
  playerStateHash      String
  termsHash            String
  submittedAt          DateTime?
  acceptedAt           DateTime?
  rejectedAt           DateTime?
  withdrawnAt          DateTime?
  expiresAtSeasonOrder Int?
  reason               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  player               Player                @relation(fields: [playerId], references: [id], onDelete: Restrict)
  offeringTeam         Team                  @relation(fields: [offeringTeamId], references: [id], onDelete: Restrict)
  startWorldSeason     WorldSeason           @relation("OfferStartSeason", fields: [startWorldSeasonId], references: [id], onDelete: Restrict)
  endWorldSeason       WorldSeason           @relation("OfferEndSeason", fields: [endWorldSeasonId], references: [id], onDelete: Restrict)
  currentContract      PlayerContract?       @relation("OfferCurrentContract", fields: [currentContractId], references: [id], onDelete: Restrict)
  draftRight           PlayerDraftRight?     @relation(fields: [draftRightId], references: [id], onDelete: Restrict)
  configVersion        ContractPresetVersion @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  resultingContract    PlayerContract?       @relation("OfferResultingContract")
  transactions         ContractTransaction[]

  @@index([playerId, status, offerType])
  @@index([offeringTeamId, status])
}

model ContractInitializationRun {
  id                String                          @id @default(cuid())
  worldSeasonId     String
  status            ContractInitializationRunStatus @default(PREPARED)
  inputHash         String
  resultHash        String?
  totalContracts    Int
  annualSalaryTotal Int
  configVersionId   String
  reason            String
  createdBy         String
  createdAt         DateTime                        @default(now())
  completedAt       DateTime?
  worldSeason       WorldSeason                     @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  configVersion     ContractPresetVersion           @relation(fields: [configVersionId], references: [id], onDelete: Restrict)

  @@index([worldSeasonId, status])
}

model ContractExpirationRun {
  id                   String                      @id @default(cuid())
  worldSeasonId        String
  effectiveSeasonOrder Int
  status               ContractExpirationRunStatus @default(PREPARED)
  inputHash            String
  resultHash           String?
  totalContracts       Int
  expiredCount         Int                         @default(0)
  activatedFutureCount Int                         @default(0)
  freeAgentCount       Int                         @default(0)
  configVersionId      String
  createdAt            DateTime                    @default(now())
  completedAt          DateTime?
  reason               String
  createdBy            String
  worldSeason          WorldSeason                 @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  configVersion        ContractPresetVersion       @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  transactions         ContractTransaction[]

  @@unique([worldSeasonId, status])
  @@index([worldSeasonId, status])
}

model ContractTransaction {
  id                     String                  @id @default(cuid())
  transactionType        ContractTransactionType
  playerId               String
  teamId                 String?
  otherTeamId            String?
  contractId             String?
  offerId                String?
  draftRightId           String?
  expirationRunId        String?
  effectiveWorldSeasonId String?
  playerNameSnapshot     String
  teamNameSnapshot       String?
  termsSnapshotText      String?
  reason                 String
  source                 String
  transactionHash        String                  @unique
  createdAt              DateTime                @default(now())
  player                 Player                  @relation(fields: [playerId], references: [id], onDelete: Restrict)
  team                   Team?                   @relation("ContractTransactionTeam", fields: [teamId], references: [id], onDelete: Restrict)
  otherTeam              Team?                   @relation("ContractTransactionOtherTeam", fields: [otherTeamId], references: [id], onDelete: Restrict)
  contract               PlayerContract?         @relation(fields: [contractId], references: [id], onDelete: Restrict)
  offer                  ContractOffer?          @relation(fields: [offerId], references: [id], onDelete: Restrict)
  draftRight             PlayerDraftRight?       @relation(fields: [draftRightId], references: [id], onDelete: Restrict)
  expirationRun          ContractExpirationRun?  @relation(fields: [expirationRunId], references: [id], onDelete: Restrict)
  effectiveWorldSeason   WorldSeason?            @relation(fields: [effectiveWorldSeasonId], references: [id], onDelete: Restrict)

  @@index([playerId, transactionType, createdAt])
  @@index([teamId, transactionType, createdAt])
}

// ---------------------------------------------------------------------------
// F29 — Trades and Rights Transfers
//
// Two-club trade proposals, immutable asset snapshots, atomic acceptance,
// completed-trade history, and append-only transfer transactions. Trades never
// rewrite historical contracts, DraftPick original ownership, DraftEvent results,
// scouting reports, lineups, or competition archives. No salary cap, retained
// salary, conditional picks, multi-team trades, or autonomous AI acceptance.
// ---------------------------------------------------------------------------

enum TradeProposalStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  WITHDRAWN
  FAILED
  EXPIRED
}

enum TradeSide {
  PROPOSING
  RECEIVING
}

enum TradeAssetType {
  PLAYER_CONTRACT
  DRAFT_PICK
  PLAYER_DRAFT_RIGHT
}

enum TradeTransactionType {
  PLAYER_TRANSFERRED
  CONTRACT_TRANSFERRED
  FUTURE_CONTRACT_TRANSFERRED
  DRAFT_PICK_TRANSFERRED
  DRAFT_RIGHT_TRANSFERRED
}

model TradePreset {
  id          String               @id @default(cuid())
  name        String               @unique
  description String?
  isSystem    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  versions    TradePresetVersion[]
}

model TradePresetVersion {
  id              String                    @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                  @default(now())
  createdBySource CommissionerAuditSource?
  preset          TradePreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor       ActiveTradeConfiguration?
  tradeProposals  TradeProposal[]
  completedTrades CompletedTrade[]

  @@unique([presetId, versionNumber])
  @@index([configHash])
}

model ActiveTradeConfiguration {
  id                    String             @id @default("default")
  activePresetVersionId String             @unique
  updatedAt             DateTime           @updatedAt
  activeVersion         TradePresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}

model TradeProposal {
  id                             String              @id @default(cuid())
  proposingTeamId                String
  receivingTeamId                String
  status                         TradeProposalStatus @default(DRAFT)
  configVersionId                String
  configHash                     String
  proposedBy                     String
  reason                         String?
  proposingTeamUpdatedAtSnapshot DateTime
  receivingTeamUpdatedAtSnapshot DateTime
  proposalHash                   String
  submittedAt                    DateTime?
  acceptedAt                     DateTime?
  rejectedAt                     DateTime?
  withdrawnAt                    DateTime?
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime            @updatedAt

  proposingTeam  Team                 @relation("TradeProposalProposingTeam", fields: [proposingTeamId], references: [id], onDelete: Restrict)
  receivingTeam  Team                 @relation("TradeProposalReceivingTeam", fields: [receivingTeamId], references: [id], onDelete: Restrict)
  configVersion  TradePresetVersion   @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  completedTrade CompletedTrade?      @relation("CompletedTradeForProposal")
  assets         TradeProposalAsset[]

  @@index([proposingTeamId, status, createdAt])
  @@index([receivingTeamId, status, createdAt])
  @@index([status, createdAt])
}

model TradeProposalAsset {
  id                    String         @id @default(cuid())
  tradeProposalId       String
  side                  TradeSide
  assetType             TradeAssetType
  playerContractId      String?
  draftPickId           String?
  playerDraftRightId    String?
  sourceTeamId          String
  targetTeamId          String
  /// Immutable, sanitized asset description (no hidden truth / private scouting).
  assetSnapshotText     String
  /// Team-context valuation snapshot (advisory only).
  valuationSnapshotText String
  valuationHash         String
  assetHash             String
  createdAt             DateTime       @default(now())

  tradeProposal    TradeProposal     @relation(fields: [tradeProposalId], references: [id], onDelete: Cascade)
  sourceTeam       Team              @relation("TradeProposalAssetTeam", fields: [sourceTeamId], references: [id], onDelete: Restrict)
  playerContract   PlayerContract?   @relation(fields: [playerContractId], references: [id], onDelete: Restrict)
  draftPick        DraftPick?        @relation(fields: [draftPickId], references: [id], onDelete: Restrict)
  playerDraftRight PlayerDraftRight? @relation(fields: [playerDraftRightId], references: [id], onDelete: Restrict)

  @@index([tradeProposalId, side])
  @@index([tradeProposalId, assetType])
  @@index([sourceTeamId])
  @@index([playerContractId])
  @@index([draftPickId])
  @@index([playerDraftRightId])
}

/// Immutable record of an accepted trade. Never edited or deleted — correction
/// uses F32 recovery or a new opposite trade where legally valid.
model CompletedTrade {
  id                        String   @id @default(cuid())
  tradeProposalId           String   @unique
  proposingTeamId           String
  receivingTeamId           String
  proposingTeamNameSnapshot String
  receivingTeamNameSnapshot String
  effectiveWorldSeasonId    String?
  configVersionId           String
  configHash                String
  tradeHash                 String
  completedAt               DateTime @default(now())
  createdAt                 DateTime @default(now())

  tradeProposal        TradeProposal         @relation("CompletedTradeForProposal", fields: [tradeProposalId], references: [id], onDelete: Restrict)
  proposingTeam        Team                  @relation("CompletedTradeProposingTeam", fields: [proposingTeamId], references: [id], onDelete: Restrict)
  receivingTeam        Team                  @relation("CompletedTradeReceivingTeam", fields: [receivingTeamId], references: [id], onDelete: Restrict)
  effectiveWorldSeason WorldSeason?          @relation("CompletedTradeEffectiveSeason", fields: [effectiveWorldSeasonId], references: [id], onDelete: Restrict)
  configVersion        TradePresetVersion    @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  assets               CompletedTradeAsset[]
  transactions         TradeTransaction[]
  transferredContracts PlayerContract[]      @relation("ContractsTransferredByTrade")

  @@index([proposingTeamId, completedAt])
  @@index([receivingTeamId, completedAt])
  @@index([completedAt])
}

model CompletedTradeAsset {
  id                 String         @id @default(cuid())
  completedTradeId   String
  side               TradeSide
  assetType          TradeAssetType
  sourceTeamId       String
  targetTeamId       String
  playerId           String?
  playerContractId   String?
  draftPickId        String?
  playerDraftRightId String?
  assetSnapshotText  String
  createdAt          DateTime       @default(now())

  completedTrade   CompletedTrade    @relation(fields: [completedTradeId], references: [id], onDelete: Cascade)
  sourceTeam       Team              @relation("CompletedTradeAssetTeam", fields: [sourceTeamId], references: [id], onDelete: Restrict)
  player           Player?           @relation(fields: [playerId], references: [id], onDelete: Restrict)
  playerContract   PlayerContract?   @relation(fields: [playerContractId], references: [id], onDelete: Restrict)
  draftPick        DraftPick?        @relation(fields: [draftPickId], references: [id], onDelete: Restrict)
  playerDraftRight PlayerDraftRight? @relation(fields: [playerDraftRightId], references: [id], onDelete: Restrict)

  @@index([completedTradeId, side])
  @@index([sourceTeamId])
  @@index([playerId])
  @@index([draftPickId])
  @@index([playerDraftRightId])
}

/// Append-only operational history for a completed trade. Avoids duplicating the
/// full proposal payload — one row per transferred asset.
model TradeTransaction {
  id                String               @id @default(cuid())
  completedTradeId  String
  transactionType   TradeTransactionType
  playerId          String?
  contractId        String?
  draftPickId       String?
  draftRightId      String?
  fromTeamId        String
  toTeamId          String
  assetNameSnapshot String
  transactionHash   String               @unique
  createdAt         DateTime             @default(now())

  completedTrade CompletedTrade    @relation(fields: [completedTradeId], references: [id], onDelete: Cascade)
  player         Player?           @relation(fields: [playerId], references: [id], onDelete: Restrict)
  contract       PlayerContract?   @relation(fields: [contractId], references: [id], onDelete: Restrict)
  draftPick      DraftPick?        @relation(fields: [draftPickId], references: [id], onDelete: Restrict)
  draftRight     PlayerDraftRight? @relation(fields: [draftRightId], references: [id], onDelete: Restrict)
  fromTeam       Team              @relation("TradeTransactionFromTeam", fields: [fromTeamId], references: [id], onDelete: Restrict)
  toTeam         Team              @relation("TradeTransactionToTeam", fields: [toTeamId], references: [id], onDelete: Restrict)

  @@index([completedTradeId, transactionType])
  @@index([playerId, transactionType, createdAt])
  @@index([fromTeamId, transactionType, createdAt])
  @@index([toTeamId, transactionType, createdAt])
  @@index([draftPickId])
  @@index([draftRightId])
}

// ---------------------------------------------------------------------------
// F30 — Offseason Workflow
//
// Persistent, resumable, Commissioner-controlled offseason orchestration. F30
// coordinates existing F20/F24/F25/F27/F28/F29 subsystems through their own
// services without duplicating their domain logic. One current official run per
// WorldSeason; phases are explicit, ordered, dependency-validated, and
// idempotent on refresh/retry. Completed phases/runs are immutable; F30 does
// not create the next WorldSeason (F31 does).
// ---------------------------------------------------------------------------

enum OffseasonRunStatus {
  PLANNED
  READY
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
  FAILED
}

enum OffseasonPhaseStatus {
  PENDING
  READY
  IN_PROGRESS
  BLOCKED
  COMPLETED
  SKIPPED
  FAILED
}

enum OffseasonPhaseEventType {
  RUN_CREATED
  RUN_STARTED
  PHASE_READY
  PHASE_STARTED
  DOMAIN_OPERATION_LINKED
  PHASE_COMPLETED
  PHASE_SKIPPED
  PHASE_FAILED
  RUN_BLOCKED
  RUN_RESUMED
  RUN_COMPLETED
  RUN_CANCELLED
}

/// Named offseason preset (system default or owner duplicate). F30.
model OffseasonPreset {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions OffseasonPresetVersion[]
}

/// Immutable offseason configuration snapshot. F30.
model OffseasonPresetVersion {
  id              String                   @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                 @default(now())
  createdBySource CommissionerAuditSource?

  preset        OffseasonPreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor     ActiveOffseasonConfiguration?
  offseasonRuns OffseasonRun[]

  @@unique([presetId, versionNumber])
  @@index([configHash])
}

/// Singleton pointing at the active offseason configuration version. F30.
model ActiveOffseasonConfiguration {
  id                    String   @id @default("default")
  activePresetVersionId String   @unique
  updatedAt             DateTime @updatedAt

  activeVersion OffseasonPresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}

/// One offseason workflow run for a WorldSeason. Exactly one current
/// non-cancelled run per WorldSeason is enforced at the service layer.
/// Completion does not create the next WorldSeason (F31 boundary). F30.
model OffseasonRun {
  id               String             @id @default(cuid())
  worldSeasonId    String
  status           OffseasonRunStatus @default(PLANNED)
  configVersionId  String
  configHash       String
  runVersion       Int                @default(1)
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  currentPhaseType String?
  readinessHash    String?
  resultHash       String?
  reason           String
  createdBy        String

  worldSeason   WorldSeason            @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  configVersion OffseasonPresetVersion @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  phases        OffseasonPhase[]
  events        OffseasonPhaseEvent[]

  @@index([worldSeasonId, status])
  @@index([status])
  @@index([configVersionId])
}

/// One ordered phase of an OffseasonRun. Status transitions are validated
/// through the engine progression module; COMPLETED/SKIPPED are immutable.
/// Linked operation ids reference existing F20/F24/F25/F27/F28 subsystem rows
/// via explicit nullable columns (no polymorphic FK). F30.
model OffseasonPhase {
  id                      String               @id @default(cuid())
  offseasonRunId          String
  phaseType               String
  phaseOrder              Int
  status                  OffseasonPhaseStatus @default(PENDING)
  required                Boolean
  allowSkip               Boolean
  competitionArchiveIds   String?
  contractExpirationRunId String?
  playerDevelopmentRunId  String?
  youthGenerationRunId    String?
  draftEventId            String?
  linkedEntityType        String?
  linkedEntityId          String?
  startedAt               DateTime?
  completedAt             DateTime?
  skippedAt               DateTime?
  failedAt                DateTime?
  readinessText           String               @default("{}")
  readinessHash           String?
  resultText              String?
  resultHash              String?
  reason                  String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  offseasonRun OffseasonRun          @relation(fields: [offseasonRunId], references: [id], onDelete: Cascade)
  events       OffseasonPhaseEvent[]

  @@unique([offseasonRunId, phaseType])
  @@index([offseasonRunId, phaseOrder])
  @@index([offseasonRunId, status])
  @@index([offseasonRunId, phaseType, status])
  @@index([contractExpirationRunId])
  @@index([playerDevelopmentRunId])
  @@index([youthGenerationRunId])
  @@index([draftEventId])
}

/// Append-only operational history for an OffseasonRun. One row per
/// orchestration event (no per-Player or per-Team audit). F30.
model OffseasonPhaseEvent {
  id               String                  @id @default(cuid())
  offseasonRunId   String
  offseasonPhaseId String?
  eventType        OffseasonPhaseEventType
  statusBefore     String?
  statusAfter      String?
  linkedEntityType String?
  linkedEntityId   String?
  summaryText      String
  reason           String                  @default("")
  eventHash        String
  createdAt        DateTime                @default(now())

  offseasonRun   OffseasonRun    @relation(fields: [offseasonRunId], references: [id], onDelete: Cascade)
  offseasonPhase OffseasonPhase? @relation(fields: [offseasonPhaseId], references: [id])

  @@index([offseasonRunId, createdAt])
  @@index([offseasonRunId, offseasonPhaseId, createdAt])
  @@index([eventType, createdAt])
}

// ---------------------------------------------------------------------------
// F31 — Season Transition (Renewable World Cycle).
// Persistent, deterministic, Commissioner-controlled season-rollover workflow
// that consumes a completed F30 OffseasonRun and creates exactly one next
// WorldSeason plus its CompetitionEditions in one atomic transaction. One
// completed transition per source WorldSeason; the target season is a new
// record, never a mutation of the source. F31 does not generate schedules,
// Matches, development, youth, draft, contracts, or trades.
// ---------------------------------------------------------------------------

enum SeasonTransitionRunStatus {
  PREPARED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SeasonTransitionEntityType {
  WORLD_SEASON
  COMPETITION_EDITION
  COMPETITION_STAGE
  COMPETITION_PARTICIPANT
  CLUB_LINEUP
  CLUB_TACTICS
  CONTRACT_STATE
  SCOUTING_STATE
  NATIONAL_TEAM_STATE
}

enum SeasonTransitionEntityAction {
  CREATED
  COPIED
  CARRIED
  MARKED_FOR_REVIEW
  PRESERVED
  SKIPPED
}

enum SeasonTransitionEventType {
  PREPARED
  STARTED
  BACKUP_CREATED
  TARGET_SEASON_CREATED
  COMPETITIONS_CREATED
  STATE_CARRIED
  COMPLETED
  FAILED
  CANCELLED
}

/// Named season-transition preset (system default or owner duplicate). F31.
model SeasonTransitionPreset {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions SeasonTransitionPresetVersion[]
}

/// Immutable season-transition configuration snapshot. F31.
model SeasonTransitionPresetVersion {
  id              String                   @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                 @default(now())
  createdBySource CommissionerAuditSource?

  preset    SeasonTransitionPreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor ActiveSeasonTransitionConfiguration?
  runs      SeasonTransitionRun[]

  @@unique([presetId, versionNumber])
  @@index([configHash])
}

/// Singleton pointing at the active season-transition configuration version. F31.
model ActiveSeasonTransitionConfiguration {
  id                    String   @id @default("default")
  activePresetVersionId String   @unique
  updatedAt             DateTime @updatedAt

  activeVersion SeasonTransitionPresetVersion @relation(fields: [activePresetVersionId], references: [id], onDelete: Restrict)
}

/// One season-transition run for a source WorldSeason. Exactly one current
/// (PREPARED/RUNNING/COMPLETED) transition per source season is enforced at the
/// service layer; completed runs are immutable. The target WorldSeason is only
/// created on atomic execution. F31.
model SeasonTransitionRun {
  id                  String                    @id @default(cuid())
  sourceWorldSeasonId String
  targetWorldSeasonId String?                   @unique
  status              SeasonTransitionRunStatus @default(PREPARED)
  configVersionId     String
  configHash          String
  runVersion          Int                       @default(1)
  targetDisplayName   String
  targetSeasonOrder   Int
  targetStartDateIso  String?
  targetEndDateIso    String?
  inputSnapshotText   String                    @default("{}")
  inputHash           String
  planSnapshotText    String                    @default("{}")
  planHash            String
  resultHash          String?
  preparedAt          DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  cancelledAt         DateTime?
  backupMetadataText  String?
  reason              String
  createdBy           String
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  sourceWorldSeason WorldSeason                    @relation("SeasonTransitionSource", fields: [sourceWorldSeasonId], references: [id], onDelete: Restrict)
  targetWorldSeason WorldSeason?                   @relation("SeasonTransitionTarget", fields: [targetWorldSeasonId], references: [id], onDelete: Restrict)
  configVersion     SeasonTransitionPresetVersion  @relation(fields: [configVersionId], references: [id], onDelete: Restrict)
  entityRecords     SeasonTransitionEntityRecord[]
  events            SeasonTransitionEvent[]

  @@index([sourceWorldSeasonId, status])
  @@index([targetWorldSeasonId])
  @@index([targetSeasonOrder])
  @@index([status])
  @@index([configVersionId])
}

/// Immutable summary of created/carried entities for a transition run. F31.
/// Prefer aggregate records for unchanged large sets (e.g. one CONTRACT_STATE
/// record summarizing all preserved ACTIVE contracts) — never one row per
/// Player.
model SeasonTransitionEntityRecord {
  id                    String                       @id @default(cuid())
  seasonTransitionRunId String
  entityType            SeasonTransitionEntityType
  sourceEntityId        String?
  targetEntityId        String?
  action                SeasonTransitionEntityAction
  snapshotText          String                       @default("{}")
  snapshotHash          String
  createdAt             DateTime                     @default(now())

  run SeasonTransitionRun @relation(fields: [seasonTransitionRunId], references: [id], onDelete: Cascade)

  @@index([seasonTransitionRunId, entityType])
  @@index([seasonTransitionRunId, sourceEntityId])
  @@index([seasonTransitionRunId, targetEntityId])
}

/// Append-only operational history for a SeasonTransitionRun. F31.
/// One row per orchestration event (no per-Player/per-Team audit).
model SeasonTransitionEvent {
  id                    String                    @id @default(cuid())
  seasonTransitionRunId String
  eventType             SeasonTransitionEventType
  statusBefore          String?
  statusAfter           String?
  summaryText           String
  reason                String                    @default("")
  eventHash             String
  createdAt             DateTime                  @default(now())

  run SeasonTransitionRun @relation(fields: [seasonTransitionRunId], references: [id], onDelete: Cascade)

  @@index([seasonTransitionRunId, createdAt])
  @@index([eventType, createdAt])
}
