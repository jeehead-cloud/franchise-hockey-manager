  COMMISSIONER_API
}

// ---------------------------------------------------------------------------
// Domain entities (F2 + F3 source metadata)
// ---------------------------------------------------------------------------

/// Global season of the single living hockey world.
model WorldSeason {
  id            String            @id @default(cuid())
  label         String            @unique
  startYear     Int
  endYear       Int
  phase         WorldSeasonPhase
  status        WorldSeasonStatus
  sourceDataset String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  competitionEditions CompetitionEdition[]
  archives            CompetitionArchive[]
  developmentRuns     PlayerDevelopmentRun[]
  playerSnapshots     PlayerSeasonSnapshot[]
  youthGenerationRuns YouthGenerationRun[]
  youthCohorts        YouthCohort[]
}

model Country {
  id              String    @id @default(cuid())
  name            String    @unique
  code            String    @unique
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  leagues               League[]
  teams                 Team[]
  players               Player[]                     @relation("PlayerNationality")
  coaches               Coach[]                      @relation("CoachNationality")
  competitions          Competition[]
  nationalTeamProfiles  NationalTeamProfile[]
  namePools             CountryNamePool[]
  youthProfileVersions  CountryYouthProfileVersion[]
  youthCohorts          YouthCohort[]
  youthGeneratedPlayers YouthGeneratedPlayer[]

  @@unique([sourceDataset, externalId])
}

model League {
  id              String                @id @default(cuid())
  name            String
  shortName       String?
  countryId       String?
  simulationLevel LeagueSimulationLevel
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  country      Country?      @relation(fields: [countryId], references: [id], onDelete: Restrict)
  teams        Team[]
  competitions Competition[]

  @@unique([countryId, name])
  @@unique([sourceDataset, externalId])
  @@index([countryId])
}

model Team {
  id              String         @id @default(cuid())
  name            String
  shortName       String?
  city            String?
  teamType        TeamType
  countryId       String
  leagueId        String?
  /// Team-wide tactical configuration (separate from coach.tacticalStyle).
  tacticalStyle   TacticalStyle?
  externalId      String?
  sourceDataset   String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict)
  league  League? @relation(fields: [leagueId], references: [id], onDelete: Restrict)

  players                 Player[]
  /// At most one current head coach (unique on Coach.currentTeamId).
  coach                   Coach?
  lineup                  TeamLineup?
  homeMatches             Match[]                  @relation("MatchHomeTeam")
  awayMatches             Match[]                  @relation("MatchAwayTeam")
  competitionParticipants CompetitionParticipant[]
  nationalTeamProfile     NationalTeamProfile?

  @@unique([leagueId, name])
  @@unique([sourceDataset, externalId])
  @@index([countryId])
  @@index([leagueId])
}

/// Player identity + F5 development profile. Attributes live in 1:1 skater/goalie tables.
/// Age: `dateOfBirth` (DateTime); age is derived later relative to world/competition date.
model Player {
  id                      String                   @id @default(cuid())
  firstName               String
  lastName                String
  dateOfBirth             DateTime
  nationalityCountryId    String
  currentTeamId           String?
  primaryPosition         PlayerPosition
  sourceType              PlayerSource
  rosterStatus            RosterStatus
  externalId              String?
  sourceDataset           String?
  sourceUpdatedAt         DateTime?
  /// F5 development profile (nullable for legacy F4 structural players).
  preferredCoachingStyle  CoachingStyle?
  preferredTactics        TacticalStyle?
  personality             Personality?
  heroRating              Int?
  stability               Int?
  developmentRate         Float?
  /// Hidden — never expose on ordinary public player APIs.
  developmentRisk         Float?
  /// Hidden — never expose on ordinary public player APIs.
  potentialFloor          Int?
  /// Hidden — never expose on ordinary public player APIs.
  potentialCeiling        Int?
  publicPotentialEstimate PublicPotentialEstimate?
  /// F24 annual form baseline (-10..10).
  form                    Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  nationality          Country                   @relation("PlayerNationality", fields: [nationalityCountryId], references: [id], onDelete: Restrict)
  currentTeam          Team?                     @relation(fields: [currentTeamId], references: [id], onDelete: SetNull)
  skaterAttributes     SkaterAttributes?
  goalieAttributes     GoalieAttributes?
  secondaryPositions   PlayerSecondaryPosition[]
  lineupAssignments    LineupAssignment[]
  developmentResults   PlayerDevelopmentResult[]
  seasonSnapshots      PlayerSeasonSnapshot[]
  youthGeneratedPlayer YouthGeneratedPlayer?

  @@unique([sourceDataset, externalId])
  @@index([nationalityCountryId])
  @@index([currentTeamId])
  @@index([primaryPosition])
  @@index([sourceType])
  @@index([rosterStatus])
}

/// Skater-only attributes (1–20). Mutual exclusion with GoalieAttributes enforced in services/import.
model SkaterAttributes {
  playerId           String   @id
  stickhandling      Int
  shooting           Int
  passing            Int
  strength           Int
  speed              Int
  balance            Int
  aggression         Int
  offensiveAwareness Int
  defensiveAwareness Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

/// Goalie-only attributes (1–20). Mutual exclusion with SkaterAttributes enforced in services/import.
model GoalieAttributes {
  playerId       String   @id
  reflexes       Int
  positioning    Int
  reboundControl Int
  glove          Int
  blocker        Int
  movement       Int
  puckHandling   Int
  consistency    Int
  stamina        Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

/// Optional secondary skater positions (F8). Goalies must have none; primary excluded.
model PlayerSecondaryPosition {
  id        String         @id @default(cuid())
  playerId  String
  position  PlayerPosition
  createdAt DateTime       @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, position])
  @@index([position])
}

/// One main lineup per team (F8). Partial lineups allowed; validation is derived.
model TeamLineup {
  id        String   @id @default(cuid())
  teamId    String   @unique
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team        Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments LineupAssignment[]
}

model LineupAssignment {
  id        String     @id @default(cuid())
  lineupId  String
  slot      LineupSlot
  playerId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  lineup TeamLineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  player Player     @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@unique([lineupId, slot])
  @@unique([lineupId, playerId])
  @@index([playerId])
}

model Coach {
  id                   String        @id @default(cuid())
  firstName            String
  lastName             String
  nationalityCountryId String?
  /// Unique when set — enforces at most one current head coach per team.
  currentTeamId        String?       @unique
  coachingStyle        CoachingStyle
  tacticalStyle        TacticalStyle
  /// F7 coach ratings (1–20). Nullable for legacy F6 rows until reimport/backfill.
  overallCoaching      Int?
  playerDevelopment    Int?
  offense              Int?
  defense              Int?
  externalId           String?
  sourceDataset        String?
  sourceUpdatedAt      DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  nationality Country? @relation("CoachNationality", fields: [nationalityCountryId], references: [id], onDelete: Restrict)
  currentTeam Team?    @relation(fields: [currentTeamId], references: [id], onDelete: SetNull)

  @@unique([sourceDataset, externalId])
  @@index([nationalityCountryId])
}

model Competition {
  id               String                      @id @default(cuid())
  name             String
  shortName        String?
  type             CompetitionType
  simulationLevel  CompetitionSimulationLevel?
  countryId        String?
  leagueId         String?
  /// Default rules template JSON (copied into edition snapshots on create).
  defaultRulesJson String?
  externalId       String?
  sourceDataset    String?
  sourceUpdatedAt  DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  country  Country?             @relation(fields: [countryId], references: [id], onDelete: Restrict)
  league   League?              @relation(fields: [leagueId], references: [id], onDelete: Restrict)
  editions CompetitionEdition[]
  archives CompetitionArchive[]

  @@unique([name, type])
  @@unique([sourceDataset, externalId])
  @@index([countryId])
  @@index([leagueId])
}

model CompetitionEdition {
  id                     String            @id @default(cuid())
  competitionId          String
  worldSeasonId          String
  displayName            String
  status                 CompetitionStatus
  editionNumber          Int?
  rulesSnapshotText      String            @default("{}")
  rulesHash              String            @default("")
  preparedAt             DateTime?
  activatedAt            DateTime?
  completedAt            DateTime?
  archivedAt             DateTime?
  /// F23 international tournament metadata (nullable for non-international editions)
  tournamentTemplateKey  String?
  tournamentTemplateText String?
  tournamentTemplateHash String?
  tournamentBaseSeed     String?
  tournamentScheduleHash String?
  tournamentBracketHash  String?
  tournamentResultHash   String?
  tournamentPreparedAt   DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  competition          Competition              @relation(fields: [competitionId], references: [id], onDelete: Restrict)
  worldSeason          WorldSeason              @relation(fields: [worldSeasonId], references: [id], onDelete: Restrict)
  participants         CompetitionParticipant[]
  stages               CompetitionStage[]
  matches              Match[]
  archives             CompetitionArchive[]
  aggregatedRuns       AggregatedSeasonRun[]
  nationalTeamEditions NationalTeamEdition[]
  tournamentMedals     TournamentMedalResult[]

  @@unique([competitionId, worldSeasonId])
  @@index([worldSeasonId])
  @@index([status])
  @@index([tournamentTemplateKey])
}

model CompetitionParticipant {
  id                    String                       @id @default(cuid())
  competitionEditionId  String
  teamId                String
  seed                  Int?
  groupKey              String?
  participantOrder      Int
  status                CompetitionParticipantStatus @default(INVITED)
  source                CompetitionParticipantSource @default(MANUAL)
  teamNameSnapshot      String
  teamShortNameSnapshot String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  edition             CompetitionEdition   @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  team                Team                 @relation(fields: [teamId], references: [id], onDelete: Restrict)
  stageParticipants   StageParticipant[]
  nationalTeamEdition NationalTeamEdition?

  @@unique([competitionEditionId, teamId])
  @@unique([competitionEditionId, participantOrder])
  @@index([teamId])
  @@index([status])
}

model CompetitionStage {
  id                       String                    @id @default(cuid())
  competitionEditionId     String
  name                     String
  stageType                CompetitionStageType
  stageOrder               Int
  status                   CompetitionStageStatus    @default(PLANNED)
  configText               String                    @default("{}")
  configHash               String                    @default("")
  participantSource        StageParticipantSource    @default(EDITION_PARTICIPANTS)
  sourceStageId            String?
  expectedQualifierCount   Int?
  /// F18 schedule metadata
  scheduleStatus           CompetitionScheduleStatus @default(NONE)
  scheduleSeed             String?
  scheduleHash             String?
  scheduleVersion          Int                       @default(0)
  scheduleGeneratedAt      DateTime?
  simulationStartedAt      DateTime?
  completedAt              DateTime?
  /// F19 playoff bracket metadata
  bracketSeed              String?
  bracketHash              String?
  bracketVersion           Int                       @default(0)
  bracketGeneratedAt       DateTime?
  championParticipantId    String?
  championTeamNameSnapshot String?
  championSeed             Int?
  championshipSeriesId     String?
  /// F21 aggregated season
  currentAggregatedRunId   String?
  simulationModeSnapshot   String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  edition           CompetitionEdition           @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  sourceStage       CompetitionStage?            @relation("StageDependency", fields: [sourceStageId], references: [id], onDelete: Restrict)
  dependents        CompetitionStage[]           @relation("StageDependency")
  participants      StageParticipant[]
  matches           Match[]
  standings         CompetitionStageStanding[]
  teamStats         CompetitionStageTeamStat[]
  playerStats       CompetitionStagePlayerStat[]
  playoffSeries     PlayoffSeries[]
  aggregatedRuns    AggregatedSeasonRun[]
  aggregatedMatches AggregatedMatchSummary[]
  tournamentMedals  TournamentMedalResult[]

  @@unique([competitionEditionId, stageOrder])
  @@index([competitionEditionId])
  @@index([stageType])
  @@index([sourceStageId])
  @@index([status])
  @@index([championParticipantId])
}

model StageParticipant {
  id                       String                       @id @default(cuid())
  competitionStageId       String
  competitionParticipantId String
  seed                     Int?
  groupKey                 String?
  stageOrder               Int
  status                   CompetitionParticipantStatus @default(CONFIRMED)
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt

  stage       CompetitionStage       @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  participant CompetitionParticipant @relation(fields: [competitionParticipantId], references: [id], onDelete: Restrict)

  @@unique([competitionStageId, competitionParticipantId])
  @@unique([competitionStageId, stageOrder])
  @@index([competitionParticipantId])
}

/// F19 best-of-series playoff matchup.
model PlayoffSeries {
  id                         String              @id @default(cuid())
  competitionStageId         String
  roundNumber                Int
  roundName                  String
  seriesOrder                Int
  bracketSlot                String
  status                     PlayoffSeriesStatus @default(PENDING)
  participant1Id             String
  participant2Id             String
  participant1Seed           Int
  participant2Seed           Int
  participant1NameSnapshot   String
  participant2NameSnapshot   String
  participant1Wins           Int                 @default(0)
  participant2Wins           Int                 @default(0)
  winsRequired               Int
  homeAdvantageParticipantId String
  homePatternText            String
  winnerParticipantId        String?
  nextSeriesId               String?
  createdAt                  DateTime            @default(now())
  startedAt                  DateTime?
  completedAt                DateTime?
  updatedAt                  DateTime            @updatedAt

  stage   CompetitionStage @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  matches Match[]

  @@unique([competitionStageId, bracketSlot])
  @@unique([competitionStageId, roundNumber, seriesOrder])
  @@index([competitionStageId, roundNumber])
  @@index([winnerParticipantId])
  @@index([status])
}

/// Append-only Commissioner edit history (F6). Exposed only via Commissioner-gated APIs.
model CommissionerAuditLog {
  id                String                      @id @default(cuid())
  entityType        CommissionerAuditEntityType
  entityId          String
  action            CommissionerAuditAction
  reason            String
  beforeJson        String
  afterJson         String
  changedFieldsJson String
  source            CommissionerAuditSource
  schemaVersion     Int                         @default(1)
  createdAt         DateTime                    @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
}

/// Named balance preset (system Standard or user duplicate). F10.
model BalancePreset {
  id          String                 @id @default(cuid())
  name        String                 @unique
  description String?
  isSystem    Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    BalancePresetVersion[]
}

/// Immutable balance configuration snapshot. F10.
model BalancePresetVersion {
  id              String                      @id @default(cuid())
  presetId        String
  versionNumber   Int
  schemaVersion   Int
  configJson      String
  configHash      String
  changeReason    String
  createdAt       DateTime                    @default(now())
  createdBySource CommissionerAuditSource?
  preset          BalancePreset               @relation(fields: [presetId], references: [id], onDelete: Restrict)
  activeFor       ActiveBalanceConfiguration?

  @@unique([presetId, versionNumber])
  @@index([configHash])
  @@index([presetId, createdAt])
}

/// Prepared or completed playable match (F14). Competition schedule fields added in F18.
model Match {
  id                            String      @id @default(cuid())
  homeTeamId                    String
  awayTeamId                    String
  competitionEditionId          String?
  competitionStageId            String?
  status                        MatchStatus @default(PREPARED)
  scheduledAt                   DateTime?
  /// Application-level pointer to current MatchResult (no FK constraint).
  currentResultId               String?
  latestSimulationAttemptNumber Int         @default(0)
  source                        MatchSource @default(MANUAL)
  createdBySource               String?
  /// Canonical match rules JSON (regulation + completion).
  rulesJson                     String?
  /// F18 competition schedule placement (nullable for ad hoc matches).
  competitionRoundNumber        Int?
  competitionSlotNumber         Int?
  scheduleKey                   String?
  scheduleOrder                 Int?
  competitionRulesHash          String?
  /// F19 playoff placement
  playoffSeriesId               String?
  playoffGameNumber             Int?
  /// F23 international group key (group-stage matches only)
  tournamentGroupKey            String?
  createdAt                     DateTime    @default(now())
  updatedAt                     DateTime    @updatedAt

  homeTeam           Team                    @relation("MatchHomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam           Team                    @relation("MatchAwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  competitionEdition CompetitionEdition?     @relation(fields: [competitionEditionId], references: [id], onDelete: Restrict)
  competitionStage   CompetitionStage?       @relation(fields: [competitionStageId], references: [id], onDelete: Restrict)
  playoffSeries      PlayoffSeries?          @relation(fields: [playoffSeriesId], references: [id], onDelete: Restrict)
  results            MatchResult[]
  tournamentMedals   TournamentMedalResult[]

  @@unique([competitionStageId, scheduleKey])
  @@unique([playoffSeriesId, playoffGameNumber])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([competitionEditionId])
  @@index([competitionStageId])
  @@index([competitionStageId, scheduleOrder])
  @@index([competitionStageId, status])
  @@index([competitionStageId, tournamentGroupKey])
  @@index([playoffSeriesId])
  @@index([status])
  @@index([scheduledAt])
}

