  @@unique([competitionEditionId, archiveHash])
  @@index([competitionId])
  @@index([worldSeasonId])
  @@index([isCurrent])
  @@index([status])
  @@index([archivedAt])
  @@index([championTeamSourceId])
}

model ArchiveParticipant {
  id                             String                @id @default(cuid())
