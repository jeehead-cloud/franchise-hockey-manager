{
  "name": "@fhm/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "verify:event-engine": "tsx src/simulation/match/verify-event-engine.ts",
    "verify:scoring-engine": "tsx src/simulation/match/verify-scoring-engine.ts",
    "verify:special-teams-engine": "tsx src/simulation/match/verify-special-teams-engine.ts",
    "verify:playable-match-engine": "tsx src/simulation/match/verify-playable-match-engine.ts",
    "verify:simulation-lab": "tsx src/simulation/batch/verify-simulation-lab.ts",
    "verify:regular-season": "tsx src/competitions/regular-season/verify-regular-season.ts",
    "verify:playoffs": "tsx src/competitions/playoffs/verify-playoffs.ts",
    "verify:archive-history": "tsx src/competitions/history/verify-archive-history.ts",
    "verify:aggregated-league": "tsx src/competitions/aggregated/verify-aggregated-league.ts",
    "verify:national-teams": "tsx src/national-teams/verify-national-teams.ts",
    "verify:international-tournaments": "tsx src/competitions/international/verify-international-tournaments.ts",
    "verify:player-development": "tsx src/development/verify-player-development.ts",
    "verify:youth-generation": "tsx src/youth-generation/verify-youth-generation.ts",
    "verify:scouting": "tsx src/scouting/verify-scouting.ts",
    "verify:draft": "tsx src/draft/verify-draft.ts",
    "verify:contracts": "tsx src/contracts/verify-contracts.ts",
    "verify:trades": "tsx src/trades/verify-trades.ts",
    "verify:offseason": "tsx src/offseason/verify-offseason.ts",
    "verify:season-transition": "tsx src/season-transition/verify-season-transition.ts",
    "verify:backup-recovery": "tsx src/backup/verify-backup.ts",
    "verify:maintenance": "tsx src/maintenance/verify-maintenance.ts"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "tsx": "^4.19.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
