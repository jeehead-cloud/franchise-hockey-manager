{
  "name": "@fhm/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "verify:event-engine": "tsx src/simulation/match/verify-event-engine.ts",
    "verify:scoring-engine": "tsx src/simulation/match/verify-scoring-engine.ts",
    "verify:special-teams-engine": "tsx src/simulation/match/verify-special-teams-engine.ts",
    "verify:playable-match-engine": "tsx src/simulation/match/verify-playable-match-engine.ts",
    "verify:simulation-lab": "tsx src/simulation/batch/verify-simulation-lab.ts",
    "verify:regular-season": "tsx src/competitions/regular-season/verify-regular-season.ts",
    "verify:playoffs": "tsx src/competitions/playoffs/verify-playoffs.ts",
    "verify:archive-history": "tsx src/competitions/history/verify-archive-history.ts"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "tsx": "^4.19.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
