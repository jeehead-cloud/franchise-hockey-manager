{
  "name": "franchise-hockey-manager",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based hockey franchise simulation",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=@fhm/server",
    "dev:client": "npm run dev --workspace=@fhm/client",
    "build": "npm run build --workspace=@fhm/engine && npm run build --workspace=@fhm/server && npm run build --workspace=@fhm/client",
    "typecheck": "npm run typecheck --workspace=@fhm/engine && npm run typecheck --workspace=@fhm/server && npm run typecheck --workspace=@fhm/client",
    "build:engine": "npm run build --workspace=@fhm/engine",
    "build:server": "npm run build --workspace=@fhm/server",
    "build:client": "npm run build --workspace=@fhm/client",
    "db:generate": "npm run db:generate --workspace=@fhm/server",
    "db:migrate": "npm run db:migrate --workspace=@fhm/server",
    "db:push": "npm run db:push --workspace=@fhm/server",
    "db:validate": "npm run db:validate --workspace=@fhm/server",
    "setup:status": "npm run setup:status --workspace=@fhm/server",
    "setup:preview": "npm run setup:preview --workspace=@fhm/server",
    "setup:validate": "npm run setup:validate --workspace=@fhm/server",
    "balance:bootstrap": "npm run balance:bootstrap --workspace=@fhm/server",
    "test": "npm run test --workspace=@fhm/engine && npm run test --workspace=@fhm/server",
    "test:engine": "npm run test --workspace=@fhm/engine",
    "test:server": "npm run test --workspace=@fhm/server",
    "verify:event-engine": "npm run verify:event-engine --workspace=@fhm/engine",
    "verify:scoring-engine": "npm run verify:scoring-engine --workspace=@fhm/engine",
    "verify:special-teams-engine": "npm run verify:special-teams-engine --workspace=@fhm/engine",
    "verify:playable-match-engine": "npm run verify:playable-match-engine --workspace=@fhm/engine",
    "verify:simulation-lab": "npm run verify:simulation-lab --workspace=@fhm/engine",
    "verify:regular-season": "npm run verify:regular-season --workspace=@fhm/engine",
    "verify:playoffs": "npm run verify:playoffs --workspace=@fhm/engine",
    "verify:archive-history": "npm run verify:archive-history --workspace=@fhm/engine",
    "verify:aggregated-league": "npm run verify:aggregated-league --workspace=@fhm/engine",
    "verify:national-teams": "npm run verify:national-teams --workspace=@fhm/engine",
    "verify:international-tournaments": "npm run verify:international-tournaments --workspace=@fhm/engine",
    "verify:player-development": "npm run verify:player-development --workspace=@fhm/engine",
    "verify:youth-generation": "npm run verify:youth-generation --workspace=@fhm/engine"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
